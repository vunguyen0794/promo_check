            <% if (!hasHot && !hasFuture && !hasPayment && !hasInstallment && !hasOther) { %>
                <div class="no-data"><i>📭</i> <p>Không có CTKM nào áp dụng cho sản phẩm này.</p></div>
            <% } %>
        </div>
    
        <% if (totalDiscount > 0) { %>
        <div class="price-summary">
            <h3 style="color:#0f172a; font-size:15px; margin: 0 0 15px 0; font-weight: 700; text-transform: uppercase;">
                🧾 Tổng tạm tính (Tham khảo)
            </h3>
            
            <div class="summary-item">
                <span style="color: #64748b;">Giá niêm yết:</span>
                <strong><%= new Intl.NumberFormat('vi-VN').format(product.list_price) %> VNĐ</strong>
            </div>
            
            <div class="summary-item">
                <span style="color: #64748b;">Tổng giảm trực tiếp (Ưu đãi Hot):</span>
                <strong style="color:#dc2626;">-<%= new Intl.NumberFormat('vi-VN').format(totalDiscount) %> VNĐ</strong>
            </div>
            
            <div class="summary-item final-price">
                <span style="color: #0f172a;">Giá khách mua:</span>
                <strong><%= new Intl.NumberFormat('vi-VN').format(finalPrice) %> VNĐ</strong>
            </div>
            
            <div style="font-size:12px; color:#94a3b8; margin-top:10px; font-style:italic;">
                * Giá trên chưa bao gồm giảm thêm từ ưu đãi thanh toán, mã giảm đơn hàng sau.
