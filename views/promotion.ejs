/* --- VOUCHER TICKET CARD (SEARCH PAGE) --- */
.voucher-tear {
    background: linear-gradient(to right, #eff6ff, #f0f9ff);
    border: 1px dashed #60a5fa;
    border-radius: 8px;
    padding: 12px 15px;
    margin-top: 10px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    /* Tạo khoảng cách an toàn 2 bên để không bị cắt chữ */
    margin-left: 6px;
    margin-right: 6px;
}

/* Tạo hiệu ứng lõm tròn (Xé) bên trái */
.voucher-tear::before {
    content: "";
    position: absolute;
    top: 50%;
    left: -7px; /* Đẩy ra mép trái */
    transform: translateY(-50%);
    width: 14px;
    height: 14px;
    background: #fff; /* Màu trùng với nền card mẹ */
    border-radius: 50%;
    border-right: 1px dashed #60a5fa; /* Viền trùng với voucher */
    box-shadow: inset -1px 0 2px rgba(0,0,0,0.05);
}

/* Tạo hiệu ứng lõm tròn (Xé) bên phải */
.voucher-tear::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -7px; /* Đẩy ra mép phải */
    transform: translateY(-50%);
    width: 14px;
    height: 14px;
    background: #fff;
    border-radius: 50%;
    border-left: 1px dashed #60a5fa;
    box-shadow: inset 1px 0 2px rgba(0,0,0,0.05);
}

