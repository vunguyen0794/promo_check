/* --- CSS FIX LỖI NÚT SLIDER (DÁN ĐÈ CŨ) --- */

/* 1. Khung bao quanh: Dùng Padding để tạo chỗ trú cho 2 nút */
.slider-wrapper {
    position: relative; /* QUAN TRỌNG: Làm gốc toạ độ */
    width: 100%;
    /* Dành ra 32px mỗi bên để đặt nút, đảm bảo nút nằm TRONG khung này */
    padding: 0 32px; 
    box-sizing: border-box; /* Tính padding vào độ rộng tổng */
}

/* 2. Khung chứa sản phẩm: Ẩn thanh cuộn */
.combo-slider-container {
    display: flex;
    overflow-x: auto; /* Cho phép trượt */
    gap: 10px;
    padding: 5px 0;
    
    /* Ẩn thanh scrollbar xấu xí */
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE */
    scroll-behavior: smooth;
}
.combo-slider-container::-webkit-scrollbar { 
    display: none; /* Chrome/Safari */ 
}

/* 3. Nút bấm: Neo sát vào lề trái/phải (trong vùng padding đã tạo) */
.nav-btn {
    position: absolute; /* Neo theo slider-wrapper */
    top: 50%;
    transform: translateY(-50%); /* Căn giữa chiều dọc */
    width: 28px;
    height: 28px;
    
    background: #fff;
    border: 1px solid #cbd5e1;
    border-radius: 50%;
    
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 20;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    
    color: #334155;
    font-size: 14px;
    font-weight: bold;
    user-select: none;
    transition: all 0.2s;
}

.nav-btn:hover {
    background: #eff6ff;
    color: #2563eb;
    border-color: #60a5fa;
    box-shadow: 0 4px 8px rgba(37, 99, 235, 0.2);
}

/* Đặt toạ độ 0 để nó nằm sát mép trong của wrapper */
.nav-prev { left: 0; } 
.nav-next { right: 0; }



