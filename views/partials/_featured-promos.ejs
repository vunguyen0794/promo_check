<%
function getExpiryInfo(endDateString) {
    if (!endDateString) {
        return {
            level: 'neutral',
            badgeClass: '',
            formattedDate: '',
            remainingLabel: 'Không giới hạn'
        };
    }

    const endDate = new Date(endDateString);
    endDate.setHours(23, 59, 59, 999);

    const now = new Date();
    const diffTime = endDate.getTime() - now.getTime();
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

    let level = 'safe';
    let badgeClass = 'promo-expiry-badge--safe';
    let remainingLabel = '';

    if (diffDays < 0) {
        level = 'expired';
        badgeClass = 'promo-expiry-badge--expired';
        remainingLabel = 'Đã hết hạn';
    } else if (diffDays <= 3) {
        level = 'urgent';
        badgeClass = 'promo-expiry-badge--urgent';
        remainingLabel = diffDays === 0 ? 'Hết hạn hôm nay' : `Còn ${diffDays} ngày`;
    } else {
        remainingLabel = `Còn ${diffDays} ngày`;
    }

    const formattedDate = new Date(endDateString).toLocaleDateString('vi-VN', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric'
    });

    return { level, badgeClass, formattedDate, remainingLabel };
}

const currentRole = (typeof userRole !== 'undefined') ? userRole : '';
const totalPageValue = Number(totalPages) || 1;
const totalItemValue = Number(totalItems) || (featuredPromos || []).length;
%>

<div class="promo-page-chunk" data-page="<%= Number(page) || 1 %>">
    <div class="promo-list">
        <% if (!featuredPromos || featuredPromos.length === 0) { %>
            <div class="promo-empty-state">
                <div class="promo-empty-state__title">Không tìm thấy CTKM phù hợp</div>
                <div class="promo-empty-state__desc">Thử đổi nhóm lọc hoặc từ khóa tìm kiếm để xem thêm kết quả.</div>
            </div>
        <% } %>

        <% (featuredPromos || []).forEach(function(p){ %>
            <% 
                const expiry = getExpiryInfo(p.end_date);
                const isKFI = (p.promo_type === 'KFI');

                if (isKFI && currentRole !== 'manager') {
                    return;
                }

                let linkHref = "/promotion-detail/" + p.id;
                let linkText = "Chi tiết CTKM";

                if (isKFI) {
                    linkHref = "/kfi-program";
                    linkText = "Xem tồn kho & thưởng";
                }
            %>

            <a class="promo-item promo-item--<%= expiry.level %>" href="<%= linkHref %>" data-expiry-level="<%= expiry.level %>">
                <div class="promo-item__head">
                    <div class="promo-chip-stack">
                        <% if (p.group_name) { %>
                            <span class="promo-chip promo-chip--group"><%= p.group_name %></span>
                        <% } %>
                        <% if (p.promo_type) { %>
                            <span class="promo-chip promo-chip--type"><%= p.promo_type %></span>
                        <% } %>
                    </div>
                    <% if (isKFI) { %>
                        <span class="promo-chip promo-chip--kfi">HOT</span>
                    <% } %>
                </div>

                <div class="promo-name"><%= p.name %></div>

                <div class="promo-meta">
                    <% 
                        const HIDE_PRICE_TYPES = ['Combo', 'Gift', 'Quà tặng (Gift)', 'Trả góp', 'Ưu đãi thanh toán', 'KFI'];
                        const shouldShowPrice = p.__display_discount && !HIDE_PRICE_TYPES.includes(p.promo_type);
                    %>

                    <% if (isKFI) { %>
                        <span class="promo-meta-text">
                            <%= p.description && p.description.includes('Thưởng') ? p.description : 'Theo dõi KFI tháng này và tồn kho liên quan' %>
                        </span>
                    <% } else if (shouldShowPrice) { %>
                        <span class="promo-price-prefix"><%= p.__display_prefix || 'Ưu đãi' %>:</span>
                        <strong class="promo-price-value">
                            <% if (String(p.__display_discount).includes('%')) { %>
                                <%= p.__display_discount %>
                            <% } else { %>
                                <%= new Intl.NumberFormat('vi-VN').format(p.__display_discount) %>₫
                            <% } %>
                        </strong>
                    <% } else { %>
                        <span class="promo-meta-text"><%= p.description ? p.description : (p.promo_type || 'Xem chi tiết') %></span>
                    <% } %>
                </div>

                <% if (expiry.formattedDate) { %>
                    <div class="promo-expiry-badge <%= expiry.badgeClass %>">HSD: <%= expiry.formattedDate %></div>
                <% } %>

                <div class="promo-item__foot">
                    <span class="promo-link-label"><%= linkText %></span>
                    <span class="promo-days-left"><%= expiry.remainingLabel %></span>
                </div>
            </a>
        <% }) %>
    </div>

    <div class="promo-fetch-meta" data-total-pages="<%= totalPageValue %>" data-total-items="<%= totalItemValue %>" style="display:none;"></div>
</div>
