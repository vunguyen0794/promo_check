      <script>
        function toggleUpdateUploadType() {
          const type = document.querySelector('#updatePolicyModal input[name="upload_type"]:checked').value;
          const fileContainer = document.getElementById('updateFileUploadContainer');
          const linkContainer = document.getElementById('updateLinkUploadContainer');
          const fileInput = document.getElementById('updateFileInput');
          const linkInput = document.getElementById('updateLinkInput');

          if (type === 'file') {
            fileContainer.style.display = 'block';
            linkContainer.style.display = 'none';
            fileInput.required = true;
            linkInput.required = false;
          } else if (type === 'link') {
            fileContainer.style.display = 'none';
            linkContainer.style.display = 'block';
            fileInput.required = false;
            linkInput.required = true;
          } else {
            fileContainer.style.display = 'none';
            linkContainer.style.display = 'none';
            fileInput.required = false;
            linkInput.required = false;
          }
        }
        function toggleCustomCategory() {
          const select = document.getElementById('categorySelect');
          const input = document.getElementById('customCategoryInput');
          if (select.value === 'Khác') {
            input.style.display = 'block';
            input.required = true;
          } else {
            input.style.display = 'none';
            input.required = false;
          }
        }

        function toggleUploadType() {
          const type = document.querySelector('input[name="upload_type"]:checked').value;
          const fileContainer = document.getElementById('fileUploadContainer');
          const linkContainer = document.getElementById('linkUploadContainer');
          const fileInput = document.getElementById('fileInput');
          const linkInput = document.getElementById('linkInput');

          if (type === 'file') {
            fileContainer.style.display = 'block';
            linkContainer.style.display = 'none';
            fileInput.required = true;
            linkInput.required = false;
          } else {
            fileContainer.style.display = 'none';
            linkContainer.style.display = 'block';
            fileInput.required = false;
            linkInput.required = true;
          }
        }

        document.addEventListener('DOMContentLoaded', () => {
          // Pagination State
          let currentPage = 1;
          const itemsPerPage = 6;
          let filteredRows = [];
          const allRows = Array.from(document.querySelectorAll('.policy-table tbody tr')).filter(row => row.id !== 'emptyRow');
          const tableWrapper = document.querySelector('.policy-table-wrapper');
          const searchInput = document.querySelector('.policy-search-input');
          const tabs = document.querySelectorAll('.filter-tab');
          
          function updateTable() {
            const searchTerm = searchInput.value.toLowerCase();
            const activeTab = document.querySelector('.filter-tab.active');
            const filterValue = activeTab ? activeTab.getAttribute('data-filter') : 'all';

            // Filter logic
            filteredRows = allRows.filter(row => {
              const textContent = row.innerText.toLowerCase();
              const type = row.getAttribute('data-type');
              const matchesSearch = textContent.includes(searchTerm);
              const matchesFilter = (filterValue === 'all' || type === filterValue);
              return matchesSearch && matchesFilter;
            });

            // Pagination calculation
            const totalItems = filteredRows.length;
            const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;
            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            // Show/Hide rows
            allRows.forEach(row => row.style.display = 'none');
            const pageRows = filteredRows.slice(startIndex, endIndex);
            pageRows.forEach(row => row.style.display = '');

            // Empty state handling
            const tbody = document.querySelector('.policy-table tbody');
            let emptyMsgRow = document.getElementById('noResultsRow');
            
            if (totalItems === 0) {
              if (!emptyMsgRow) {
                emptyMsgRow = document.createElement('tr');
                emptyMsgRow.id = 'noResultsRow';
                emptyMsgRow.innerHTML = `<td colspan="6" style="text-align:center; padding:30px; color:#94a3b8;">Không tìm thấy kết quả phù hợp.</td>`;
                tbody.appendChild(emptyMsgRow);
              }
              emptyMsgRow.style.display = '';
            } else if (emptyMsgRow) {
              emptyMsgRow.style.display = 'none';
            }
            
            // Server-side empty row guard
            const serverEmptyRow = document.getElementById('emptyRow');
            if (serverEmptyRow) serverEmptyRow.style.display = (totalItems === 0 && !searchTerm && filterValue === 'all') ? '' : 'none';

            // Update UI
            document.getElementById('paginationInfo').innerText = `Hiển thị ${totalItems > 0 ? startIndex + 1 : 0}-${Math.min(endIndex, totalItems)} / ${totalItems} tài liệu`;
            
            const prevBtn = document.getElementById('prevPage');
            const nextBtn = document.getElementById('nextPage');
            
            prevBtn.disabled = currentPage === 1;
            prevBtn.style.opacity = currentPage === 1 ? '0.5' : '1';
            prevBtn.style.cursor = currentPage === 1 ? 'not-allowed' : 'pointer';

            nextBtn.disabled = currentPage === totalPages;
            nextBtn.style.opacity = currentPage === totalPages ? '0.5' : '1';
            nextBtn.style.cursor = currentPage === totalPages ? 'not-allowed' : 'pointer';
          }

          // Initial render
          updateTable();

          // Event Listeners for Pagination
          document.getElementById('prevPage').addEventListener('click', () => {
            if (currentPage > 1) {
              currentPage--;
              updateTable();
              document.querySelector('.policy-table-container').scrollTop = 0;
            }
          });

          document.getElementById('nextPage').addEventListener('click', () => {
            const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
            if (currentPage < totalPages) {
              currentPage++;
              updateTable();
              document.querySelector('.policy-table-container').scrollTop = 0;
            }
          });

          // Tab switching
          tabs.forEach(tab => {
            tab.addEventListener('click', () => {
              tabs.forEach(t => t.classList.remove('active'));
              tab.classList.add('active');
              currentPage = 1;
              updateTable();
            });
          });

          // Search logic
          if (searchInput) {
            searchInput.addEventListener('input', () => {
              currentPage = 1;
              updateTable();
            });

            // Scroll to table only on Enter or clicking the icon
            const handleSearchScroll = () => {
              if (searchInput.value.length > 0) {
                tableWrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            };

            searchInput.addEventListener('keydown', (e) => {
              if (e.key === 'Enter') handleSearchScroll();
            });

            const searchIcon = document.querySelector('.policy-search-bar span');
            if (searchIcon) {
              searchIcon.style.cursor = 'pointer';
              searchIcon.addEventListener('click', handleSearchScroll);
            }
          }

          // Row selection logic
          const tableRowsForSelection = document.querySelectorAll('.policy-table tbody tr');
          tableRowsForSelection.forEach(row => {
            row.addEventListener('click', () => {
              if (row.id === 'emptyRow' || row.cells.length === 1) return;

              // Remove active class from all rows
              tableRowsForSelection.forEach(r => r.classList.remove('active'));
              // Add active class to clicked row
              row.classList.add('active');

              // Extract data attributes for History Timeline
              const policyId = row.dataset.id;
              const docName = row.dataset.title || row.querySelector('.doc-name').innerText;
              const updateStr = row.dataset.updated || row.cells[4].innerText;
              const summaryHtml = row.dataset.summary || '';
              let historyData = [];
              try {
                historyData = JSON.parse(row.dataset.history || '[]');
              } catch (e) { console.error('Error parsing history:', e); }

              // Setup global states for Update Modal
              window.selectedPolicyId = policyId;
              window.selectedPolicyTitle = docName;
              window.selectedPolicySummary = summaryHtml;

              const btnUpdate = document.getElementById('btnOpenUpdateModal');
              if (btnUpdate) btnUpdate.style.display = 'flex';

              // Update UI headers
              const aiTitle = document.querySelector('.ai-selected h6');
              const aiDate = document.querySelector('.ai-selected span');
              const timelineContainer = document.querySelector('.history-timeline');
              const summaryContainer = document.querySelector('.doc-summary-section');
              const summaryContent = document.querySelector('.doc-summary-content');
              // Danh sách history
              const versionSelect = document.getElementById('versionSummarySelect');
              if (versionSelect) {
                 versionSelect.innerHTML = '<option value="latest">Bản hiện tại</option>';
                 window.policyVersionSummaries = { latest: summaryHtml };
                 
                 let hasOtherSummaries = false;
                 // Lọc bỏ những bản ghi history có tóm tắt giống hệt bản hiện tại để tránh trùng lặp
                 const cleanSummaryHtml = (summaryHtml || '').trim();
                 
                 historyData.slice().reverse().forEach((evt, idx) => {
                    const evtSummary = (evt.summary || '').trim();
                    if (evtSummary !== '' && evtSummary !== cleanSummaryHtml) {
                       const opt = document.createElement('option');
                       const verId = 'v_' + idx + '_' + new Date(evt.time).getTime();
                       opt.value = verId;
                       opt.innerText = evt.action + ' (' + new Date(evt.time).toLocaleDateString('vi-VN') + ')';
                       versionSelect.appendChild(opt);
                       window.policyVersionSummaries[verId] = evt.summary;
                       hasOtherSummaries = true;
                    }
                 });

                 if (hasOtherSummaries || (cleanSummaryHtml !== '' && cleanSummaryHtml !== 'Chưa có tóm tắt')) {
                    versionSelect.style.display = 'block';
                 } else {
                    versionSelect.style.display = 'none';
                 }
                 versionSelect.value = 'latest';
              }

              if (aiTitle) aiTitle.innerText = docName;
              if (aiDate) aiDate.innerText = 'Cập nhật: ' + updateStr;

              // Render Summary Container always if there's any summary or dropdown available
              if (summaryContainer && summaryContent) {
                const hasCurrentSummary = (summaryHtml && summaryHtml.trim() !== '' && summaryHtml !== 'Chưa có tóm tắt');
                if (hasCurrentSummary || (versionSelect && versionSelect.style.display !== 'none')) {
                  summaryContainer.style.display = 'block';
                  // Force render the latest to start
                  if (typeof changeSummaryVersion === 'function') {
                    changeSummaryVersion('latest');
                  } else {
                    summaryContent.innerHTML = hasCurrentSummary ? summaryHtml : '<em>Không có tóm tắt.</em>';
                  }
                } else {
                  summaryContainer.style.display = 'none';
                }
              }

              // Render Timeline
              if (timelineContainer) {
                timelineContainer.innerHTML = '';
                if (historyData.length === 0) {
                  timelineContainer.innerHTML = '<div style="color: #94a3b8; font-size: 13px; text-align:center; padding: 20px 0;">Không có dữ liệu lịch sử.</div>';
                } else {
                  // Render array in reverse (newest first)
                  historyData.slice().reverse().forEach(evt => {
                    const dateObj = new Date(evt.time);
                    const formattedDate = !isNaN(dateObj) ? dateObj.toLocaleString('vi-VN', {
                      day: '2-digit', month: '2-digit', year: 'numeric',
                      hour: '2-digit', minute: '2-digit'
                    }) : evt.time;

                    timelineContainer.innerHTML += `
                                <div class="timeline-item">
                                    <div class="timeline-date">${formattedDate}</div>
                                    <div class="timeline-action">${evt.action}</div>
                                    <div class="timeline-note">${evt.note || ''}</div>
                                    <div class="timeline-user">
                                        <span class="material-symbols-outlined" style="font-size: 12px;">person</span> ${evt.created_by || 'Unknown'}
                                        ${evt.file_url ? `<a href="${evt.file_url.split(/[,\n]/)[0]}" target="_blank" style="margin-left: 8px; color: #3b82f6; text-decoration: none;"><span class="material-symbols-outlined" style="font-size: 12px; vertical-align: middle;">link</span> File</a>` : ''}
                                    </div>
                                </div>
                            `;
                  });
                }
              }

              // Optional: add a small animation effect
              const aiPanel = document.querySelector('.ai-panel');
              if (aiPanel) {
                aiPanel.style.opacity = '0.5';
                setTimeout(() => aiPanel.style.opacity = '1', 200);
              }
            });
          });
        });

        function changeSummaryVersion(val) {
           const summaryContent = document.querySelector('.doc-summary-content');
           if (!summaryContent || !window.policyVersionSummaries) return;
           let html = window.policyVersionSummaries[val] || '';
           if (!/<[a-z][\s\S]*>/i.test(html)) {
              html = html.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" style="color: #60a5fa; text-decoration: underline;">$1</a>');
           }

           // Auto-render KaTeX syntax $$...$$ for older imported notes
           if (typeof katex !== 'undefined' && html.includes('$$')) {
             html = html.replace(/\$\$([\s\S]+?)\$\$/g, (match, formula) => {
               try {
                 // Quill might inject HTML tags or &nbsp; inside the $$ block when pasting
                 // We need to extract just the raw text of the formula
                 let cleanFormula = formula.replace(/<br\s*[\/]?>/gi, '\n') // Replace <br> with newline for LaTeX
                                           .replace(/<[^>]*>?/gm, '')       // Strip all other HTML tags
                                           .replace(/&nbsp;/ig, ' ')        // Replace non-breaking spaces
                                           .replace(/&amp;/ig, '&')         // Replace amps
                                           .replace(/&lt;/ig, '<')          // Replace <
                                           .replace(/&gt;/ig, '>')          // Replace >
                                           .trim();
                 return katex.renderToString(cleanFormula, { throwOnError: false, displayMode: true });
               } catch (e) {
                 console.error('KaTeX err:', e);
                 return match; // fallback
               }
             });
           }

           summaryContent.innerHTML = html;
           summaryContent.querySelectorAll('a').forEach(a => {
              a.setAttribute('target', '_blank');
              a.style.color = '#60a5fa';
              a.style.textDecoration = 'underline';
           });
           summaryContent.querySelectorAll('img').forEach(img => {
              img.style.maxWidth = '100%';
              img.style.borderRadius = '8px';
              img.style.marginTop = '8px';
           });
        }

        // Close modal if clicked outside
        window.onclick = function (event) {
          const modal = document.getElementById('uploadPolicyModal');
          if (event.target == modal) {
            modal.style.display = "none";
          }
        }

        function openUpdateModal() {
          if (!window.selectedPolicyId) return alert('Vui lòng chọn một tài liệu trước.');
          document.getElementById('updatePolicyId').value = window.selectedPolicyId;
          document.getElementById('updatePolicyTitle').value = window.selectedPolicyTitle;
          
          // The user requested that the update summary editor starts empty so they can write a fresh summary
          // for the new version rather than having to manually delete the old one.
          if(window.updateQuill) {
             window.updateQuill.root.innerHTML = '';
          }
          
          document.getElementById('updatePolicyModal').style.display = 'flex';
        }

        // Initialize Quill editors after DOM loads
        document.addEventListener('DOMContentLoaded', () => {
           const toolbarOptions = [
              ['bold', 'italic', 'underline', 'strike'],
              ['blockquote', 'code-block'],
              [{ 'list': 'ordered'}, { 'list': 'bullet' }],
              [{ 'color': [] }, { 'background': [] }],
              [{ 'table': [] }], /* Enable tables */
              ['link', 'image', 'video', 'formula'], /* Enable formula */
              ['clean']
           ];

           if(document.getElementById('summaryEditor')) {
              window.uploadQuill = new Quill('#summaryEditor', {
                 theme: 'snow',
                 modules: {
                   formula: true,
                   toolbar: toolbarOptions,
                   table: true
                 }
              });
              document.getElementById('uploadPolicyForm').addEventListener('submit', function(e) {
                 document.getElementById('summaryHiddenInput').value = window.uploadQuill.root.innerHTML;
              });
           }

           if(document.getElementById('updateSummaryEditor')) {
              window.updateQuill = new Quill('#updateSummaryEditor', {
                 theme: 'snow',
                 modules: {
                   formula: true,
                   toolbar: toolbarOptions,
                   table: true
                 }
              });
              document.getElementById('updatePolicyForm').addEventListener('submit', function(e) {
                 document.getElementById('updateSummaryHiddenInput').value = window.updateQuill.root.innerHTML;
              });
           }
        });
      </script>

      </body>

      </html>