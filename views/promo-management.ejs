<script>
    // 1. Hàm bật/tắt khung cấu hình
    function toggleTierConfig() {
        const checkbox = document.getElementById('trigger_tier_price');
        const container = document.getElementById('tier-price-config');
        
        if (checkbox && container) {
            container.style.display = checkbox.checked ? 'block' : 'none';
            
            // Nếu bật lên mà chưa có dòng nào thì tự thêm 1 dòng mẫu
            const tbody = document.getElementById('tier-rows');
            if (checkbox.checked && tbody.children.length === 0) {
                addTierRow();
            }
        }
    }

    // 2. Hàm thêm dòng mốc mới
    function addTierRow(data = {}) {
        const tbody = document.getElementById('tier-rows');
        const tr = document.createElement('tr');
        
        const qty = data.min_qty || 2;
        const disc = data.discount || 0;
        const type = data.type || 'amount'; // amount hoặc percent

        tr.innerHTML = `
            <td>
                <input type="number" class="form-control form-control-sm text-center tier-qty" 
                       value="${qty}" min="1" step="1" required placeholder="Nhập SL">
            </td>
            <td>
                <input type="number" class="form-control form-control-sm text-end tier-disc" 
                       value="${disc}" min="0" required placeholder="Nhập mức giảm">
            </td>
            <td>
                <select class="form-select form-select-sm tier-type">
                    <option value="amount" ${type === 'amount' ? 'selected' : ''}>VNĐ (đ)</option>
                    <option value="percent" ${type === 'percent' ? 'selected' : ''}>Phần trăm (%)</option>
                </select>
            </td>
            <td>
                <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="this.closest('tr').remove()">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </td>
        `;
        tbody.appendChild(tr);
    }

    // 3. Xử lý khi trang vừa tải xong (Dành cho trang Edit Promotion)
    document.addEventListener('DOMContentLoaded', function() {
        // Kiểm tra xem có dữ liệu cũ từ server truyền xuống không (dùng EJS)
        <% if (typeof promotion !== 'undefined' && promotion.detail_fields && promotion.detail_fields.tiers) { %>
            const savedTiers = <%- JSON.stringify(promotion.detail_fields.tiers) %>;
            
            if (Array.isArray(savedTiers) && savedTiers.length > 0) {
                // 1. Check vào ô kích hoạt
                const checkbox = document.getElementById('trigger_tier_price');
                if(checkbox) checkbox.checked = true;

                // 2. Load các dòng dữ liệu
                const tbody = document.getElementById('tier-rows');
                tbody.innerHTML = ''; // Xóa trắng trước khi load
                savedTiers.forEach(t => addTierRow(t));

                // 3. Hiển thị khung
                toggleTierConfig();
            }
        <% } %>
    });

    // 4. Xử lý trước khi Submit Form (Gom dữ liệu vào input hidden)
    const createForm = document.getElementById('createPromoForm');
    if (createForm) {
        createForm.addEventListener('submit', function(e) {
            const checkbox = document.getElementById('trigger_tier_price');
            
            // Chỉ xử lý nếu checkbox được kích hoạt
            if (checkbox && checkbox.checked) {
                const rows = document.querySelectorAll('#tier-rows tr');
                const tiers = [];
                let isValid = true;

                rows.forEach(row => {
                    const qty = parseInt(row.querySelector('.tier-qty').value) || 0;
                    const discount = parseFloat(row.querySelector('.tier-disc').value) || 0;
                    const type = row.querySelector('.tier-type').value;

                    if (qty <= 0) isValid = false;
                    
                    // Chỉ lấy dòng có dữ liệu hợp lệ
                    if (qty > 0) {
                        tiers.push({ min_qty: qty, discount: discount, type: type });
                    }
                });

                if (!isValid) {
                    alert('Số lượng mua phải lớn hơn 0.');
                    e.preventDefault(); return;
                }

                if (tiers.length === 0) {
                    alert('Bạn đã kích hoạt Tier Price nhưng chưa nhập mốc số lượng nào.');
                    e.preventDefault(); return;
                }

                // Sắp xếp tăng dần theo số lượng
                tiers.sort((a, b) => a.min_qty - b.min_qty);

                // Gán vào input hidden
                const detailObj = { tiers: tiers };
                document.getElementById('detail_json_input').value = JSON.stringify(detailObj);
            } else {
                // Nếu không kích hoạt, đảm bảo gửi lên null hoặc object rỗng để server biết đường xóa cũ
                document.getElementById('detail_json_input').value = JSON.stringify({});
            }
        }, true); // true = capture phase runs BEFORE the async handler at bubble phase
    }
</script>

<script>
    // --- SEARCH & FILTER (LEGACY) ---
    (function () {
        const legacy = document.getElementById('promoSearch');
        const form = document.getElementById('filterForm');
        const qHidden = document.getElementById('qHidden');
        const toggle = document.querySelector('.filter-toggle');
        if (!legacy || !form || !qHidden || !toggle) return;

        let t;
        function debounce(fn, ms) { clearTimeout(t); t = setTimeout(fn, ms); }

        legacy.addEventListener('input', () => {
            qHidden.value = legacy.value;
            const v = (legacy.value || '').trim().toLowerCase();
            document.querySelectorAll('.promo-card').forEach(c => {
                const name = (c.getAttribute('data-name') || '').toLowerCase();
                c.style.display = name.includes(v) ? '' : 'none';
            });
            debounce(() => form.submit(), 350);
        });

        toggle.addEventListener('click', () => {
            form.classList.toggle('show');
        });
        document.addEventListener('click', (e) => {
            if (!form.classList.contains('show')) return;
            if (!e.target.closest('.filter-popover') && !e.target.closest('.filter-toggle')) {
                form.classList.remove('show');
            }
        });
    })();

    // --- MAIN MODAL LOGIC ---
    function showCreateModal() {
    const form = document.getElementById('createPromoForm');
    if (form) {
        form.reset(); // Reset các input cơ bản
        
        // Reset các biến đếm dynamic
        giftIndex = 0; 
        comboIndex = 0; 
        couponIndex = 0;

        // Xóa sạch các container dynamic cũ
        document.getElementById('giftContainer').innerHTML = '';
        document.getElementById('comboContainer').innerHTML = '';
        document.getElementById('couponListContainer').innerHTML = '';
        
        // Xóa nội dung trong các ô Rich Text Editor (RTE)
        document.querySelectorAll('.rte-field').forEach(div => div.innerHTML = '');

        // Ẩn các block đặc biệt để về trạng thái mặc định
        handlePromoTypeChange(); 
        toggleDiscountInputs();
        toggleCouponBuilder();
        toggleScopeFields();
    }
    
    document.getElementById('createPromoModal').style.display = 'block';
    document.body.classList.add('modal-open');
}

    function handlePromoTypeChange() {
        const type = document.getElementById('promoTypeSelect').value;
        const blocks = ['blockBasicValue', 'blockNextOrder', 'blockInstallment', 'blockGift', 'blockCombo'];
        
        // 1. Ẩn tất cả và RESET giá trị của các block bị ẩn
        blocks.forEach(id => {
            const block = document.getElementById(id);
            if (!block) return;

            // Mặc định ẩn
            block.style.display = 'none';

            // Logic reset: Tìm tất cả input/select trong block này và xóa giá trị
            // Điều này đảm bảo khi block ẩn đi, nó không gửi data rác lên server
            const inputs = block.querySelectorAll('input, select, textarea');
            inputs.forEach(input => {
                if (input.type === 'checkbox' || input.type === 'radio') {
                    input.checked = false;
                } else if (input.tagName === 'SELECT') {
                    input.selectedIndex = 0; // Về option đầu tiên (thường là --Chọn--)
                } else {
                    input.value = '';
                }
            });
            
            // Xóa nội dung dynamic (Gift/Combo list) nếu cần thiết
            if (id === 'blockGift') document.getElementById('giftContainer').innerHTML = '';
            if (id === 'blockCombo') document.getElementById('comboContainer').innerHTML = '';
        });

        // 2. Hiện block tương ứng theo loại CTKM
        if (type === 'Tặng mã giảm đơn hàng sau') {
            document.getElementById('blockNextOrder').style.display = 'block';
        }
        else if (type.includes('Trả góp')) {
            document.getElementById('blockInstallment').style.display = 'block';
        }
        else if (type === 'Gift') {
            document.getElementById('blockGift').style.display = 'block';
            if(document.getElementById('giftContainer').children.length === 0) addGiftOption();
        }
        else if (type === 'Combo') {
            document.getElementById('blockCombo').style.display = 'block';
            if(document.getElementById('comboContainer').children.length === 0) addComboRow();
        }
        else {
            // Mặc định hiện Basic Value cho các loại còn lại (Coupon, Voucher, v.v.)
            document.getElementById('blockBasicValue').style.display = 'block';
        }
    }



    function toggleDiscountInputs() {
        const t = document.getElementById('discount_value_type').value;
        document.getElementById('amountBox').style.display = (t === 'amount') ? 'block' : 'none';
        document.getElementById('percentBox').style.display = (t === 'percent') ? 'block' : 'none';
        document.getElementById('capBox').style.display = (t === 'percent') ? 'block' : 'none';
    }

    function toggleScopeFields() {
        const type = document.getElementById('applyToTypeSelect').value;
        const fields = { sku: 'skuField', brand: 'brandField', category: 'categoryField', subcat: 'subcatField' };
        for (let k in fields) document.getElementById(fields[k]).style.display = 'none';
        
        if (type === 'brand_subcat') {
            document.getElementById('brandField').style.display = 'block';
            document.getElementById('subcatField').style.display = 'block';
        } else if (fields[type]) {
            document.getElementById(fields[type]).style.display = 'block';
        }
    }

    // --- YÊU CẦU 2: GROUP SELECTION ---
    window.handleGroupSelection = function(selectId, pickerId, isSelect) {
        const groupName = document.getElementById(pickerId).value;
        if(!groupName) return;
        const select = document.getElementById(selectId);
        Array.from(select.options).forEach(opt => {
            if(opt.getAttribute('data-group') === groupName) {
                opt.selected = isSelect;
            }
        });
    }

    // --- DYNAMIC BUILDERS ---
    let giftIndex = 0;
    let comboIndex = 0;
    let couponIndex = 0;

    function addSkuInputToGroup(containerId, fieldNameBase) {
        const container = document.getElementById(containerId);
        const div = document.createElement('div');
        div.className = 'sku-link-row';
        div.innerHTML = `
            <input type="text" name="${fieldNameBase}[]" class="form-control" style="width:130px;" placeholder="Nhập SKU" onblur="checkSkuInfo(this, this.nextElementSibling)">
            <div class="sku-info-display" style="font-size:12px; color:#64748b; flex:1;"></div>
            <button type="button" onclick="this.parentElement.remove()" style="color:red; border:none; background:none; cursor:pointer;">×</button>
        `;
        container.appendChild(div);
    }

    function addGiftOption() {
        const idx = giftIndex++;
        const container = document.getElementById('giftContainer');
        const skuContainerId = `gift-skus-${idx}`;
        
        const div = document.createElement('div');
        div.className = 'gift-option';
        div.innerHTML = `
            <div class="remove-row-btn" onclick="this.parentElement.remove()">×</div>
            <div style="font-weight:bold; margin-bottom:5px; color:#b45309">Option (ID: ${idx})</div>
            <div class="form-group">
                <input type="text" name="detail[gift_options][${idx}][code]" class="form-control" placeholder="Mã Coupon/Voucher (nếu có)">
            </div>
            <label style="font-size:12px; font-weight:600;">Danh sách sản phẩm quà tặng:</label>
            <div id="${skuContainerId}" style="margin-bottom:5px;"></div>
            <button type="button" onclick="addSkuInputToGroup('${skuContainerId}', 'detail[gift_options][${idx}][skus]')" style="font-size:12px; color:#2563eb; background:none; border:none; cursor:pointer;">+ Thêm SKU quà</button>
        `;
        container.appendChild(div);
        addSkuInputToGroup(skuContainerId, `detail[gift_options][${idx}][skus]`);
    }

    function addComboRow() {
        const idx = comboIndex++;
        const container = document.getElementById('comboContainer');
        const skuContainerId = `combo-skus-${idx}`;
        
        const div = document.createElement('div');
        div.className = 'combo-row';
        div.innerHTML = `
            <div class="remove-row-btn" onclick="this.parentElement.remove()">×</div>
            <div style="font-weight:bold; margin-bottom:5px; color:#4338ca">Bộ Combo (ID: ${idx})</div>
            <label style="font-size:12px; font-weight:600;">Các sản phẩm trong Combo:</label>
            <div id="${skuContainerId}" style="margin-bottom:8px;"></div>
            <button type="button" onclick="addSkuInputToGroup('${skuContainerId}', 'detail[combos][${idx}][skus]')" style="font-size:12px; color:#2563eb; background:none; border:none; cursor:pointer;">+ Thêm SKU vào combo</button>
            <div class="form-row" style="margin-top:10px; border-top:1px dashed #e5e7eb; padding-top:8px;">
                <input type="number" name="detail[combos][${idx}][discount_val]" class="form-control" placeholder="Giá trị giảm">
                <select name="detail[combos][${idx}][discount_type]" class="form-control">
                    <option value="amount">Giảm tiền</option>
                    <option value="percent">Giảm %</option>
                </select>
            </div>
        `;
        container.appendChild(div);
        addSkuInputToGroup(skuContainerId, `detail[combos][${idx}][skus]`);
        addSkuInputToGroup(skuContainerId, `detail[combos][${idx}][skus]`);
    }

    function toggleCouponBuilder() {
        const checked = document.getElementById('hasCouponListCheckbox').checked;
        document.getElementById('couponListBuilder').style.display = checked ? 'block' : 'none';
        document.getElementById('couponCodeInput').style.display = checked ? 'none' : 'block';
        if (checked && document.getElementById('couponListContainer').children.length === 0) addCouponRow();
    }

    function addCouponRow() {
        const idx = couponIndex++;
        const div = document.createElement('div');
        div.style.cssText = 'display:grid; grid-template-columns: 1fr 1fr 1fr 1fr 30px; gap:8px; margin-bottom:5px;';
        div.innerHTML = `
            <input type="text" name="coupons[${idx}][name]" class="form-control" placeholder="Tên/Nhóm">
            <input type="text" name="coupons[${idx}][code]" class="form-control" placeholder="Mã Code" required style="font-weight:bold; color:#b45309;">
            <input type="text" name="coupons[${idx}][discount]" class="form-control" placeholder="Mức giảm">
            <input type="text" name="coupons[${idx}][note]" class="form-control" placeholder="Ghi chú">
            <button type="button" onclick="this.parentElement.remove()" style="color:red; border:none; background:none; cursor:pointer; font-weight:bold;">×</button>
        `;
        document.getElementById('couponListContainer').appendChild(div);
    }

    // --- YÊU CẦU 4: SKU INFO CHECKER (Name + Stock) ---
    async function checkSkuInfo(inputEl, displayEl) {
        const sku = inputEl.value.trim();
        if(!sku) { displayEl.innerHTML = ''; return; }
        
        displayEl.innerHTML = '<span style="color:#94a3b8; font-size:11px;">🔄 Đang tải...</span>';
        
        try {
            // [CẬP NHẬT] Gọi API mới chuyên dụng cho Admin
            const res = await fetch(`/api/admin/search-sku-stock?q=${encodeURIComponent(sku)}`);
            const json = await res.json();
            
            if(json.ok && json.results && json.results.length > 0) {
                // Lấy kết quả chính xác nhất (SKU khớp hoàn toàn) hoặc kết quả đầu tiên
                const found = json.results.find(i => i.sku == sku) || json.results[0];
                
                // Hiển thị Tên & Tồn kho
                const stockColor = found.stock > 0 ? '#16a34a' : '#dc2626'; // Xanh nếu còn, Đỏ nếu hết
                const priceStr = new Intl.NumberFormat('vi-VN').format(found.list_price || 0);

                displayEl.innerHTML = `
                    <div style="line-height:1.3;">
                        <div style="color:#0f172a; font-weight:600; font-size:12px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:250px;" title="${found.product_name}">
                            ${found.product_name}
                        </div>
                        <div style="font-size:11px;">
                            <span style="color:#64748b;">${priceStr}đ</span> 
                            <span style="margin:0 4px; color:#cbd5e1;">|</span> 
                            <span style="color:${stockColor}; font-weight:700;">Tồn: ${found.stock}</span>
                        </div>
                    </div>
                `;
            } else {
                displayEl.innerHTML = `<span style="color:#dc2626; font-size:12px;">❌ Không tìm thấy SP</span>`;
            }
        } catch(e) {
            console.error(e);
            displayEl.innerHTML = `<span style="color:#dc2626; font-size:12px;">⚠️ Lỗi kết nối</span>`;
        }
    }

    
  
    let savedRange = null;

    // 1. Xử lý lưu vị trí con trỏ khi rời khỏi ô nhập liệu
    document.querySelectorAll('.rte-field').forEach(div => {
        div.addEventListener('blur', () => {
            const sel = window.getSelection();
            if (sel.rangeCount > 0) {
                savedRange = sel.getRangeAt(0);
            }
        });
        // Khi focus lại, reset savedRange để tránh xung đột
        div.addEventListener('focus', () => {
            savedRange = null;
        });
    });

    // 2. Xử lý các nút B, I, U, Link
    document.querySelectorAll('.rte-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            // [QUAN TRỌNG] Nếu là nút chọn màu (input type color), KHÔNG được preventDefault
            // Nếu chặn, bảng màu sẽ không hiện ra.
            if (btn.id === 'rteColor') return; 

            e.preventDefault(); // Chặn hành động mặc định cho các nút button thường
            
            const cmd = btn.dataset.cmd;
            if(cmd) document.execCommand(cmd, false, null);
            
            if(btn.id === 'rteLink') {
                const url = prompt('URL:', 'https://');
                if(url) document.execCommand('createLink', false, url);
            }
        });
    });

    // 3. Xử lý khi chọn màu xong (sự kiện input)
    document.getElementById('rteColor').addEventListener('input', (e) => {
        // Khôi phục vùng chọn cũ (nếu có) trước khi tô màu
        if (savedRange) {
            const sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(savedRange);
        } else {
            // Nếu không có vùng chọn, focus lại vào ô editor đầu tiên (fallback)
            const firstEditor = document.querySelector('.rte-field');
            if (firstEditor) firstEditor.focus();
        }

        // Lệnh tô màu: styleWithCSS để dùng span style="color:..." thay vì thẻ font cũ
        document.execCommand('styleWithCSS', false, true);
        document.execCommand('foreColor', false, e.target.value);
    });

    // Handle Submit (Code mới đã fix lỗi đơ nút)
    document.getElementById('createPromoForm').addEventListener('submit', async function(e) {
        e.preventDefault(); // Chặn reload trang ngay lập tức
        console.log("Đang xử lý tạo CTKM..."); // Kiểm tra xem code có chạy không

        const btn = this.querySelector('button[type="submit"]');
        const oldText = btn.innerText;

        // 1. Khóa nút để tránh bấm nhiều lần
        btn.disabled = true;
        btn.innerText = "Đang lưu...";

        try {
            // 2. Đồng bộ dữ liệu từ khung soạn thảo (RTE) vào thẻ textarea ẩn
            document.querySelectorAll('.rte-field').forEach((div) => {
                const name = div.getAttribute('data-name');
                const ta = div.parentElement.querySelector('textarea[name="' + name + '"]');
                if (ta) ta.value = div.innerHTML;
            });

            // 3. Chuẩn bị dữ liệu gửi đi
            // Sử dụng URLSearchParams để server nodejs (body-parser) tự động hiểu các field detail[...]
            const formData = new FormData(this);
            const urlEncodedData = new URLSearchParams(formData);

            // 4. Gửi Request lên Server
            const res = await fetch('/create-promotion', {
                method: 'POST',
                body: urlEncodedData,
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
                }
            });

            const result = await res.json();

            if (result.success) {
                alert('✅ Tạo thành công!');
                window.location.reload();
            } else {
                throw new Error(result.error || 'Lỗi không xác định từ server');
            }

        } catch (err) {
            console.error("Lỗi submit:", err);
            alert('❌ Lỗi: ' + err.message);
        } finally {
            // 5. Mở lại nút dù thành công hay thất bại để không bị cứng đơ
            btn.disabled = false;
            btn.innerText = oldText;
        }
    });
    // Copy/Delete functions (Legacy)
    async function copyPromo(id) {
        if (!confirm("Sao chép CTKM #" + id + "?")) return;
        try {
            const res = await fetch(`/api/promotions/${id}/clone`, { method: 'POST' });
            const js = await res.json();
            if (js.ok) window.location.href = `/edit-promotion/${js.new_id}`;
            else alert(js.error);
        } catch (e) { alert(e.message); }
    }
    
    function deletePromo(id) {
        if(confirm("Xóa CTKM này?")) {
            fetch(`/api/promotions/${id}`, { method: 'DELETE' })
            .then(r=>r.json()).then(d=>{ if(d.success) location.reload(); else alert(d.error); });
        }
    }

    // --- [MỚI] HÀM XỬ LÝ IMPORT KFI ---
    async function doImportKFI() {
        const rawData = document.getElementById('inpKfiData').value;
        if(!rawData.trim()) return alert('⚠️ Vui lòng dán dữ liệu vào ô trống!');
        
        if(!confirm('Bạn có chắc muốn cập nhật bảng KFI với dữ liệu này?')) return;

        // Đổi nút bấm thành trạng thái đang tải
        const btn = event.target;
        const oldText = btn.innerText;
        btn.innerText = "Đang xử lý...";
        btn.disabled = true;

        try {
            const res = await fetch('/api/admin/import-kfi', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ rawData })
            });
            const json = await res.json();
            
            if(json.ok) {
                alert(`✅ Thành công! Đã cập nhật ${json.count} dòng KFI.`);
                document.getElementById('modalImportKFI').style.display = 'none';
                document.getElementById('inpKfiData').value = ''; // Xóa dữ liệu cũ
            } else {
                alert('❌ Lỗi: ' + json.error);
            }
        } catch(e) { 
            console.error(e);
            alert('❌ Lỗi hệ thống: ' + e.message); 
        } finally {
            btn.innerText = oldText;
            btn.disabled = false;
        }
    }

    // --- [MỚI] LOGIC BULK DELETE & SELECT ALL ---
    
    const checkAllBtn = document.getElementById('checkAll');
    const actionBar = document.getElementById('bulkActionBar');
    const countDisplay = document.getElementById('selectedCount');

    // 1. Xử lý nút "Chọn tất cả"
    if (checkAllBtn) {
        checkAllBtn.addEventListener('change', function() {
            const isChecked = this.checked;
            document.querySelectorAll('.bulk-check').forEach(cb => cb.checked = isChecked);
            updateBulkAction();
        });
    }


    // Cập nhật hàm này trong script cũ của bạn
    window.updateBulkAction = function() {
        const checkedCount = document.querySelectorAll('.bulk-check:checked').length;
        if(countDisplay) countDisplay.textContent = checkedCount;
        
        if (actionBar) {
            if (checkedCount > 0) {
                // Thay vì display block, ta dùng class để animate
                actionBar.classList.add('visible'); 
                // Đảm bảo display flex để layout ko bị vỡ (nếu css set display none ban đầu)
                actionBar.style.display = 'flex'; 
            } else {
                actionBar.classList.remove('visible');
            }
        }
    }
    // 3. Hàm bỏ chọn tất cả
    window.deselectAll = function() {
        document.querySelectorAll('.bulk-check').forEach(cb => cb.checked = false);
        if(checkAllBtn) checkAllBtn.checked = false;
        updateBulkAction();
    }

    // 4. Gửi request xóa hàng loạt
    window.submitBulkDelete = async function() {
        const checkedBoxes = document.querySelectorAll('.bulk-check:checked');
        const ids = Array.from(checkedBoxes).map(cb => parseInt(cb.value));

        if (ids.length === 0) return;

        if (!confirm(`⚠️ CẢNH BÁO: Bạn có chắc chắn muốn XÓA VĨNH VIỄN ${ids.length} chương trình khuyến mãi này không?\nHành động này không thể hoàn tác!`)) {
            return;
        }

        try {
            const btn = document.querySelector('.btn-bulk-delete');
            const oldText = btn.textContent;
            btn.textContent = "Đang xóa...";
            btn.disabled = true;

            const res = await fetch('/api/promotions/bulk-delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ids })
            });

            const json = await res.json();

            if (json.ok) {
                alert('✅ ' + json.message);
                window.location.reload();
            } else {
                alert('❌ Lỗi: ' + json.error);
                btn.textContent = oldText;
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Lỗi kết nối mạng.');
        }
    }
</script>

