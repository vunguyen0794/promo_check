<script>
    async function openBuildPcTiersModal() {
        document.getElementById('buildPcTiersModal').style.display = 'flex';
        var tbody = document.getElementById('tiersTableBody');
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:20px;color:#94a3b8;">Đang tải...</td></tr>';
        try {
            var res = await fetch('/api/admin/build-pc-tiers');
            var data = await res.json();
            tbody.innerHTML = '';
            if (data.ok && data.tiers) data.tiers.forEach(function(t){ addTierRowBpc(t); });
        } catch(e) { tbody.innerHTML = '<tr><td colspan="4" style="color:red;">Lỗi</td></tr>'; }
    }
    function closeBuildPcTiersModal() { document.getElementById('buildPcTiersModal').style.display = 'none'; }
    function addTierRowBpc(tier) {
        tier = tier || {};
        var tbody = document.getElementById('tiersTableBody');
        var row = document.createElement('tr');
        row.className = 'tier-row';
        row.innerHTML =
            '<td style="padding:8px;border-bottom:1px solid #f1f5f9;"><input type="number" class="tier-min" value="'+(tier.min||'')+'" placeholder="VD: 10000000" style="width:100%;padding:8px;border:1px solid #e2e8f0;border-radius:6px;"></td>' +
            '<td style="padding:8px;border-bottom:1px solid #f1f5f9;"><input type="number" class="tier-discount" value="'+(tier.discount||'')+'" placeholder="VD: 200000" style="width:100%;padding:8px;border:1px solid #e2e8f0;border-radius:6px;"></td>' +
            '<td style="padding:8px;border-bottom:1px solid #f1f5f9;"><input type="text" class="tier-code" value="'+(tier.code||'')+'" placeholder="VD: PVBPC260XX" style="width:100%;padding:8px;border:1px solid #e2e8f0;border-radius:6px;font-family:monospace;"></td>' +
            '<td style="padding:8px;border-bottom:1px solid #f1f5f9;text-align:center;"><button onclick="this.closest(\'tr\').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;">X</button></td>';
        tbody.appendChild(row);
    }
    async function saveBuildPcTiers() {
        var rows = document.querySelectorAll('#tiersTableBody .tier-row');
        var tiers = []; var valid = true;
        rows.forEach(function(row) {
            var min = parseInt(row.querySelector('.tier-min').value);
            var discount = parseInt(row.querySelector('.tier-discount').value);
            var code = row.querySelector('.tier-code').value.trim();
            if (isNaN(min) || isNaN(discount) || !code) { valid = false; return; }
            tiers.push({ min:min, discount:discount, code:code });
        });
        if (!valid || tiers.length === 0) { alert('Vui lòng điền đầy đủ.'); return; }
        var btn = document.getElementById('btnSaveTiers');
        btn.disabled = true; btn.textContent = 'Đang lưu...';
        try {
            var res = await fetch('/api/admin/build-pc-tiers', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({tiers:tiers}) });
            var data = await res.json();
            if (data.ok) { alert('✅ ' + data.message); closeBuildPcTiersModal(); }
            else { alert('❌ Lỗi: ' + (data.error || '')); }
        } catch(e) { alert('❌ Lỗi kết nối.'); }
        finally { btn.disabled = false; btn.textContent = '💾 Lưu cài đặt'; }
    }
</script>

