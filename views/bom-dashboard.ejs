<%- include('partials/header', { title, currentPage }) %>

<style>
  /* ======================================================
     BOM DASHBOARD - MODERN REDESIGN
     ====================================================== */
  .bom-page { padding: 0; }

  /* ── KPI Header cards ── */
  .bom-kpi-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }
  .bom-kpi {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
    transition: box-shadow .2s ease;
  }
  .bom-kpi:hover { box-shadow: 0 6px 20px rgba(0,0,0,.08); }
  .bom-kpi .kpi-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #64748b;
  }
  .bom-kpi .kpi-value {
    font-size: 26px;
    font-weight: 800;
    color: #0f172a;
    line-height: 1;
  }
  .bom-kpi .kpi-sub {
    font-size: 11px;
    color: #94a3b8;
  }
  .bom-kpi.danger  { border-color: #fca5a5; background: #fff5f5; }
  .bom-kpi.danger .kpi-value { color: #dc2626; }
  .bom-kpi.success { border-color: #86efac; background: #f0fdf4; }
  .bom-kpi.success .kpi-value { color: #16a34a; }
  .bom-kpi.info    { border-color: #93c5fd; background: #eff6ff; }
  .bom-kpi.info .kpi-value   { color: #2563eb; }

  /* ── Bottleneck radar panel ── */
  .bottleneck-radar {
    background: linear-gradient(135deg, #fff7ed 0%, #fff 70%);
    border: 1px solid #fed7aa;
    border-radius: 16px;
    padding: 16px 20px;
    margin-bottom: 20px;
  }
  .bottleneck-radar-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .bottleneck-radar-title {
    font-size: 14px; font-weight: 800; color: #9a3412;
    display: flex; align-items: center; gap: 6px;
  }
  .bottleneck-radar-badge {
    background: #fef3c7; border: 1px solid #fcd34d;
    color: #92400e; border-radius: 999px;
    padding: 3px 10px; font-size: 11px; font-weight: 700;
  }
  .bottleneck-chips {
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .bottleneck-chip {
    background: #fff; border: 1px solid #fdba74;
    border-radius: 10px; padding: 8px 12px;
    display: flex; flex-direction: column; gap: 3px;
    min-width: 170px; max-width: 220px;
    box-shadow: 0 2px 5px rgba(251,146,60,.1);
  }
  .bottleneck-chip .chip-sku { font-size: 12px; font-weight: 800; color: #7c2d12; }
  .bottleneck-chip .chip-name { font-size: 11px; color: #9a3412; line-height: 1.4; }
  .bottleneck-chip .chip-stats { display: flex; gap: 6px; margin-top: 3px; }
  .bottleneck-chip .chip-stats span {
    font-size: 10px; font-weight: 700;
    border-radius: 999px; padding: 2px 7px;
    background: #ffedd5; color: #c2410c; border: 1px solid #fdba74;
  }
  .bottleneck-empty-msg {
    font-size: 13px; color: #15803d;
    background: #dcfce7; border: 1px solid #86efac;
    border-radius: 10px; padding: 10px 14px; font-weight: 600;
  }

  /* ── Toolbar ── */
  .bom-toolbar {
    display: flex; flex-wrap: wrap; gap: 10px;
    align-items: center; margin-bottom: 16px;
  }
  .bom-search-input {
    flex: 1; min-width: 220px;
    border: 1px solid #cbd5e1; border-radius: 10px;
    padding: 9px 14px; font-size: 14px; background: #fff;
    transition: border-color .2s ease, box-shadow .2s ease;
  }
  .bom-search-input:focus {
    outline: none; border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,.18);
  }
  .bom-filter-btns { display: flex; gap: 6px; flex-wrap: wrap; }
  .bom-filter-btns .btn { font-size: 12px; padding: 6px 12px; border-radius: 8px; }
  .bom-filter-btns .btn.active {
    background: #2563eb; color: #fff; border-color: #2563eb;
  }
  .bom-sort-select {
    border: 1px solid #cbd5e1; background: #fff;
    border-radius: 10px; padding: 8px 12px; font-size: 13px; font-weight: 600;
    color: #334155; cursor: pointer;
  }

  /* ── Type tabs ── */
  .bom-type-tabs {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-bottom: 14px;
    border-bottom: 2px solid #f1f5f9;
    padding-bottom: 14px;
  }
  .bom-type-tab {
    text-decoration: none; padding: 7px 16px;
    border-radius: 999px; font-size: 13px; font-weight: 700;
    color: #64748b; background: #f8fafc; border: 1px solid transparent;
    transition: all .2s ease;
  }
  .bom-type-tab:hover { background: #e2e8f0; color: #334155; }
  .bom-type-tab.active {
    background: #2563eb; color: #fff; border-color: #1d4ed8;
    box-shadow: 0 4px 14px rgba(37,99,235,.25);
  }

  /* ── Main Product Cards ── */
  .bom-card-list { display: flex; flex-direction: column; gap: 12px; }

  .bom-product-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,.05);
    transition: box-shadow .2s ease, border-color .2s ease;
  }
  .bom-product-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.09); }
  .bom-product-card.has-bottleneck { border-color: #fca5a5; }
  .bom-product-card.all-good { border-color: #86efac; }

  .bom-product-header {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 16px; cursor: pointer;
    user-select: none;
  }
  .bom-product-header:hover { background: #f8fafc; }

  .bom-toggle-btn {
    width: 28px; height: 28px; flex-shrink: 0;
    border: 1px solid #e2e8f0; border-radius: 50%;
    background: #f8fafc; color: #64748b;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 13px; transition: all .2s ease; cursor: pointer;
  }
  .bom-toggle-btn.open { background: #eff6ff; border-color: #93c5fd; color: #2563eb; }
  .bom-toggle-btn .chevron { transition: transform .25s ease; display: inline-block; }
  .bom-toggle-btn.open .chevron { transform: rotate(180deg); }

  .bom-product-info { flex: 1; min-width: 0; }
  .bom-product-sku {
    font-size: 12px; font-weight: 800; color: #2563eb;
    margin-bottom: 2px; letter-spacing: .02em;
  }
  .bom-product-name {
    font-size: 14px; font-weight: 700; color: #0f172a;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .bom-product-badges { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }
  .bom-badge {
    font-size: 11px; font-weight: 700; border-radius: 999px;
    padding: 3px 9px; border: 1px solid transparent;
  }
  .bom-badge.ok { background: #dcfce7; color: #15803d; border-color: #86efac; }
  .bom-badge.warn { background: #fef9c3; color: #854d0e; border-color: #fde047; }
  .bom-badge.danger { background: #fee2e2; color: #dc2626; border-color: #fca5a5; }

  .bom-stock-summary {
    display: flex; gap: 16px; flex-shrink: 0;
    align-items: center; text-align: right;
  }
  .bom-stock-block .sb-label {
    font-size: 10px; font-weight: 700; text-transform: uppercase; color: #94a3b8;
    letter-spacing: .04em;
  }
  .bom-stock-block .sb-value {
    font-size: 20px; font-weight: 800; color: #0f172a; line-height: 1.1;
  }
  .bom-stock-block .sb-value.blue { color: #2563eb; }
  .bom-branch-pills {
    display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end;
    margin-top: 4px;
  }
  .branch-pill {
    font-size: 10px; font-weight: 700; border-radius: 6px;
    padding: 3px 7px; border: 1px solid #e2e8f0; background: #f8fafc;
    color: #334155; white-space: nowrap;
  }
  .branch-pill.bp-ok { background: #dcfce7; border-color: #86efac; color: #15803d; }
  .branch-pill.bp-warn { background: #fef9c3; border-color: #fde047; color: #854d0e; }
  .branch-pill.bp-danger { background: #fee2e2; border-color: #fca5a5; color: #dc2626; }

  /* ── Component detail block ── */
  .bom-components-panel {
    display: none;
    border-top: 1px solid #f1f5f9;
    background: #f8fafc;
    padding: 12px 16px;
    flex-direction: column;
    gap: 8px;
  }
  .bom-components-panel.open { display: flex; }
  .bom-comp-header {
    font-size: 11px; font-weight: 800; text-transform: uppercase;
    letter-spacing: .06em; color: #94a3b8; margin-bottom: 4px;
    padding-bottom: 6px; border-bottom: 1px dashed #e2e8f0;
  }
  .bom-comp-item {
    display: grid;
    grid-template-columns: 200px auto 1fr;
    align-items: center;
    gap: 12px;
    background: #fff; border: 1px solid #e2e8f0;
    border-radius: 10px; padding: 9px 14px;
    transition: border-color .15s ease;
  }
  .bom-comp-item.comp-bottleneck {
    border-color: #fca5a5; background: #fff5f5;
  }
  .bom-comp-item.comp-ok { border-color: #86efac; background: #f0fdf4; }
  .bom-comp-meta { min-width: 0; }
  .bom-comp-sku  { font-size: 11px; font-weight: 800; color: #2563eb; white-space: nowrap; }
  .bom-comp-name { font-size: 12px; font-weight: 600; color: #0f172a; margin-top: 1px; }
  .bom-comp-req {
    font-size: 12px; color: #64748b; white-space: nowrap;
    background: #f1f5f9; border-radius: 999px; display: inline-block;
    padding: 3px 10px; font-weight: 700; text-align: center;
  }
  .bom-comp-stocks { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; justify-content: flex-end; }
  .comp-stock-chip {
    display: flex; flex-direction: column; align-items: center;
    border: 1px solid #e2e8f0; border-radius: 8px;
    padding: 5px 9px; min-width: 72px; background: #f8fafc; gap: 1px;
  }
  .comp-stock-chip .csc-branch {
    font-size: 9px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .04em; color: #94a3b8;
  }
  .comp-stock-chip .csc-have {
    font-size: 20px; font-weight: 800; line-height: 1.1;
  }
  .comp-stock-chip .csc-need {
    font-size: 9px; color: #94a3b8; font-weight: 600;
  }
  .comp-stock-chip.csc-ok { border-color: #86efac; background: #f0fdf4; }
  .comp-stock-chip.csc-ok .csc-have { color: #16a34a; }
  .comp-stock-chip.csc-danger { border-color: #fca5a5; background: #fff5f5; }
  .comp-stock-chip.csc-danger .csc-have { color: #dc2626; }
  .comp-stock-chip.csc-warn { border-color: #fde047; background: #fefce8; }
  .comp-stock-chip.csc-warn .csc-have { color: #ca8a04; }

  /* ── No-result / Empty ── */
  .bom-empty {
    text-align: center; padding: 60px 20px; color: #64748b;
  }
  .bom-empty .bom-empty-icon { font-size: 48px; margin-bottom: 12px; }
  .bom-empty p { font-size: 14px; }

  /* ── Pagination ── */
  .bom-pagination {
    display: flex; justify-content: center; align-items: center;
    flex-wrap: wrap; gap: 8px; margin-top: 24px;
  }
  .bom-pagination a.btn[disabled] { pointer-events: none; opacity: .5; }
  .bom-pagination select {
    padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 8px;
    font-size: 13px; cursor: pointer;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .bom-toolbar { flex-direction: column; align-items: stretch; }
    .bom-product-header { flex-wrap: wrap; gap: 8px; }
    .bom-stock-summary { flex-direction: row; justify-content: flex-start; }
    .bom-kpi-strip { grid-template-columns: repeat(2, 1fr); }
    .bom-comp-stocks { justify-content: flex-start; }
  }
</style>

<%
  const numberOf = (value) => Number(value || 0);
  const branchScope = isGlobalAdmin ? branches : (userBranch ? [userBranch] : []);
  let totalFinalStockPage = 0;
  let totalBuildablePage = 0;
  let totalGapPage = 0;
  let totalSkusHavingBottleneck = 0;
  const bottleneckAccumulator = new Map();

  (results || []).forEach((row) => {
    totalFinalStockPage += numberOf(row.finalStock_Total);
    totalBuildablePage  += numberOf(row.buildable_Total);
    totalGapPage        += Math.max(0, numberOf(row.finalStock_Total) - numberOf(row.buildable_Total));

    let rowHasBottleneck = false;
    (row.components || []).forEach((comp) => {
      const needQty = Math.max(1, numberOf(comp.need || 1));
      let componentShortage = 0;
      let componentAffected = 0;
      branchScope.forEach((branchName) => {
        const haveQty = numberOf(comp.branches?.[branchName]?.have);
        if (haveQty < needQty) {
          componentAffected += 1;
          componentShortage += (needQty - haveQty);
          rowHasBottleneck = true;
        }
      });
      if (componentAffected > 0) {
        const cache = bottleneckAccumulator.get(comp.sku) || { sku: comp.sku, name: comp.name || 'Linh kiện', shortageQty: 0, affectedBranches: 0 };
        cache.shortageQty    += componentShortage;
        cache.affectedBranches += componentAffected;
        bottleneckAccumulator.set(comp.sku, cache);
      }
    });
    if (rowHasBottleneck) totalSkusHavingBottleneck += 1;
  });

  const topBottlenecks = Array.from(bottleneckAccumulator.values())
    .sort((a, b) => (b.shortageQty !== a.shortageQty) ? b.shortageQty - a.shortageQty : b.affectedBranches - a.affectedBranches)
    .slice(0, 10);

  // URL helpers
  const baseSearch = (typeof searchQuery !== 'undefined' && searchQuery) ? 'q=' + encodeURIComponent(searchQuery) : '';
  const currentType = (typeof filterType !== 'undefined' && filterType) ? filterType : '';
  const buildFilterUrl = (typeValue) => {
    const params = [];
    if (typeValue) params.push('type=' + encodeURIComponent(typeValue));
    if (baseSearch)  params.push(baseSearch);
    return '?' + params.join('&');
  };
  const buildPageUrl = (nextPage) => {
    const params = ['page=' + nextPage];
    if (currentType) params.push('type=' + encodeURIComponent(currentType));
    if (baseSearch)  params.push(baseSearch);
    return '?' + params.join('&');
  };
%>

<div class="dash-card bom-page">

  <!-- ── Tiêu đề ── -->
  <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px; margin-bottom:20px;">
    <div>
      <div class="dash-title">📦 Dashboard Năng Lực Lắp Ráp</div>
      <p style="margin-top:6px; color:#64748b; font-size:13px;">
        Theo dõi tồn kho thành phẩm, năng lực ráp và linh kiện nghẽn
        <% if (!isGlobalAdmin && userBranch) { %> – Chi nhánh <strong><%= userBranch %></strong><% } %>
      </p>
    </div>
    <div style="font-size:12px; color:#94a3b8; align-self:flex-end;">
      🔄 Dữ liệu từ kho thực tế · <%= new Date().toLocaleString('vi-VN') %>
    </div>
  </div>

  <!-- ── KPI Strip ── -->
  <div class="bom-kpi-strip">
    <div class="bom-kpi info">
      <span class="kpi-label">SKU hiển thị</span>
      <span class="kpi-value"><%= results.length %></span>
      <span class="kpi-sub">/ <%= totalItems %> tổng</span>
    </div>
    <div class="bom-kpi">
      <span class="kpi-label">Tổng tồn kho</span>
      <span class="kpi-value"><%= totalFinalStockPage %></span>
      <span class="kpi-sub">Thành phẩm (trang này)</span>
    </div>
    <div class="bom-kpi success">
      <span class="kpi-label">Ráp được</span>
      <span class="kpi-value"><%= totalBuildablePage %></span>
      <span class="kpi-sub">Bộ từ linh kiện hiện có</span>
    </div>
    <div class="bom-kpi <%= totalSkusHavingBottleneck > 0 ? 'danger' : 'success' %>">
      <span class="kpi-label">SKU thiếu linh kiện</span>
      <span class="kpi-value"><%= totalSkusHavingBottleneck %></span>
      <span class="kpi-sub">/ <%= results.length %> SKU</span>
    </div>
    <div class="bom-kpi <%= totalGapPage > 0 ? 'danger' : '' %>">
      <span class="kpi-label">Chênh Tồn-Ráp được</span>
      <span class="kpi-value"><%= totalGapPage %></span>
      <span class="kpi-sub">Tổng khoảng thiếu</span>
    </div>
  </div>

  <!-- ── Radar Nút Cổ Chai ── -->
  <div class="bottleneck-radar">
    <div class="bottleneck-radar-head">
      <span class="bottleneck-radar-title">🚨 Radar Linh Kiện Nghẽn (Top <%= topBottlenecks.length %>)</span>
      <span class="bottleneck-radar-badge">Ảnh hưởng <%= totalSkusHavingBottleneck %> SKU</span>
    </div>
    <% if (topBottlenecks.length > 0) { %>
      <div class="bottleneck-chips">
        <% topBottlenecks.forEach(item => { %>
          <div class="bottleneck-chip">
            <div class="chip-sku"><%= item.sku %></div>
            <div class="chip-name"><%= item.name %></div>
            <div class="chip-stats">
              <span>Thiếu: <%= item.shortageQty %></span>
              <span><%= item.affectedBranches %> NH</span>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="bottleneck-empty-msg">✅ Không có linh kiện nghẽn trên trang này. Đội lắp ráp sạch nước kèo!</div>
    <% } %>
  </div>

  <!-- ── Toolbar: Filter + Search ── -->
  <div class="bom-toolbar">
    <form method="GET" action="/bom-dashboard" style="display:contents;">
      <input type="text" name="q" class="bom-search-input"
             placeholder="🔍 Tìm SKU hoặc Tên thành phẩm..."
             value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
      <button type="submit" class="btn btn-primary" style="padding:9px 16px;">Tìm</button>
      <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
        <a href="/bom-dashboard" class="btn btn-secondary">✕ Xóa</a>
      <% } %>
    </form>
    <select id="bomSortSelect" class="bom-sort-select">
      <option value="default">Sắp xếp: Mặc định</option>
      <option value="buildableAsc">Ráp được thấp nhất</option>
      <option value="gapDesc">Chênh lệch cao nhất</option>
      <option value="bottleneckDesc">Nhiều linh kiện thiếu nhất</option>
    </select>
    <div class="bom-filter-btns">
      <button type="button" id="btnShowAll" class="btn btn-secondary active" aria-pressed="true">Tất cả</button>
      <button type="button" id="btnOnlyReady" class="btn btn-secondary" aria-pressed="false">✅ Đủ LK</button>
      <button type="button" id="btnOnlyMissing" class="btn btn-secondary" aria-pressed="false">🚨 Thiếu LK</button>
    </div>
    <div style="display:flex; gap:6px;">
      <button type="button" id="btnExpandAll" class="btn btn-secondary">Mở tất cả</button>
      <button type="button" id="btnCollapseAll" class="btn btn-secondary">Thu gọn</button>
      <button type="button" id="btnExportCsv" class="btn btn-primary">⬇ CSV</button>
    </div>
  </div>

  <!-- ── Type Tabs ── -->
  <div class="bom-type-tabs">
    <a href="<%= buildFilterUrl('') %>" class="bom-type-tab <%= (!currentType) ? 'active' : '' %>">Tất cả PCPV</a>
    <a href="<%= buildFilterUrl('vanphong') %>" class="bom-type-tab <%= (currentType === 'vanphong') ? 'active' : '' %>">🖥 Văn phòng</a>
    <a href="<%= buildFilterUrl('gaming') %>" class="bom-type-tab <%= (currentType === 'gaming') ? 'active' : '' %>">🎮 Gaming</a>
  </div>

  <p class="dash-muted" style="margin-bottom:14px;">
    Trang <strong><%= page %>/<%= totalPages %></strong> · Tổng <strong><%= totalItems %></strong> SKU thành phẩm
    · <span style="font-size:12px; color:#94a3b8;">Cần/Tồn: số cần cho 1 bộ / số thực tế trong kho</span>
  </p>

  <!-- ── Card List ── -->
  <div class="bom-card-list" id="bomCardList">
    <% if (results.length === 0) { %>
      <div class="bom-empty">
        <div class="bom-empty-icon">📭</div>
        <p>Không tìm thấy SKU thành phẩm nào.<br>Thử thay đổi từ khóa hoặc bộ lọc nhé.</p>
      </div>
    <% } %>

    <% results.forEach(row => { %>
      <%
        let rowBottleneckCount = 0;
        const rowGap = Math.max(0, numberOf(row.finalStock_Total) - numberOf(row.buildable_Total));

        // Pre-calc per-component bottleneck status for this row's scope
        const compStatusMap = new Map();
        (row.components || []).forEach((comp) => {
          const needQty = Math.max(1, numberOf(comp.need || 1));
          let compShort = false;
          branchScope.forEach((br) => {
            const haveQty = numberOf(comp.branches?.[br]?.have);
            if (haveQty < needQty) compShort = true;
          });
          compStatusMap.set(comp.sku, compShort);
          if (compShort) rowBottleneckCount++;
        });

        const cardClass = rowBottleneckCount > 0 ? 'has-bottleneck' : 'all-good';
      %>
      <div class="bom-product-card <%= cardClass %>"
           data-sku="<%= row.sku %>"
           data-final-stock="<%= numberOf(row.finalStock_Total) %>"
           data-buildable="<%= numberOf(row.buildable_Total) %>"
           data-gap="<%= rowGap %>"
           data-bottleneck-count="<%= rowBottleneckCount %>">

        <!-- Card Header (clickable to expand) -->
        <div class="bom-product-header" onclick="toggleBomCard(this)">
          <button type="button" class="bom-toggle-btn" aria-label="Mở/Đóng linh kiện">
            <span class="chevron">▾</span>
          </button>

          <div class="bom-product-info">
            <div class="bom-product-sku"><%= row.sku %> <span style="font-weight:500; color:#475569; font-size:12px;">– <%= row.name %></span></div>
            <div class="bom-product-badges">
              <% if (rowBottleneckCount > 0) { %>
                <span class="bom-badge danger">🚨 Thiếu <%= rowBottleneckCount %> LK</span>
              <% } else { %>
                <span class="bom-badge ok">✅ Đủ linh kiện</span>
              <% } %>
              <% if (rowGap > 0) { %>
                <span class="bom-badge warn">⚠ Chênh Tồn-Ráp: <%= rowGap %></span>
              <% } %>
              <span class="bom-badge" style="background:#f1f5f9; color:#475569; border-color:#e2e8f0;"><%= row.components.length %> linh kiện</span>
            </div>
          </div>

          <!-- Stock blocks per-branch summary -->
          <div class="bom-stock-summary">
            <!-- Global Admin thấy tất cả branches -->
            <% if (isGlobalAdmin) { %>
              <div class="bom-stock-block">
                <div class="sb-label">Tổng Tồn</div>
                <div class="sb-value"><%= numberOf(row.finalStock_Total) %></div>
                <div class="bom-branch-pills">
                  <% branches.forEach(br => { %>
                    <% const tonBr = numberOf(row.finalStock_ByBranch[br]); %>
                    <% const rapBr = numberOf(row.buildable_ByBranch[br]); %>
                    <span class="branch-pill" title="<%= br %> - Tồn:<%= tonBr %> Ráp:<%= rapBr %>"><%= br %>: <%= tonBr %>/<%= rapBr %></span>
                  <% }); %>
                </div>
              </div>
            <% } else if (userBranch) { %>
              <div class="bom-stock-block">
                <div class="sb-label">Tồn kho</div>
                <div class="sb-value"><%= numberOf(row.finalStock_ByBranch[userBranch]) || 0 %></div>
              </div>
              <div class="bom-stock-block">
                <div class="sb-label">Ráp được</div>
                <div class="sb-value blue"><%= numberOf(row.buildable_ByBranch[userBranch]) || 0 %></div>
              </div>
            <% } else { %>
              <div class="bom-stock-block">
                <div class="sb-label">Tồn</div>
                <div class="sb-value"><%= numberOf(row.finalStock_Total) %></div>
              </div>
              <div class="bom-stock-block">
                <div class="sb-label">Ráp được</div>
                <div class="sb-value blue"><%= numberOf(row.buildable_Total) %></div>
              </div>
            <% } %>
          </div>
        </div><!-- /bom-product-header -->

        <!-- Component Detail Panel (hidden by default) -->
        <div class="bom-components-panel">
          <div class="bom-comp-header">Chi tiết linh kiện</div>
          <% if (row.components.length === 0) { %>
            <div style="font-size:13px; color:#64748b; padding:6px 0;">Không có linh kiện trong BOM.</div>
          <% } %>
          <% row.components.forEach(comp => { %>
            <%
              const needQty = Math.max(1, numberOf(comp.need || 1));
              const isCompBottleneck = compStatusMap.get(comp.sku) || false;
              const compClass = isCompBottleneck ? 'comp-bottleneck' : 'comp-ok';
              const totalHave = Object.values(comp.branches || {}).reduce((s, b) => s + numberOf(b.have), 0);
            %>
            <div class="bom-comp-item <%= compClass %>">
              <div class="bom-comp-meta">
                <div class="bom-comp-sku"><%= comp.sku %></div>
                <div class="bom-comp-name"><%= comp.name %></div>
                <span class="bom-comp-req">Cần: <b><%= needQty %></b> / bộ</span>
              </div>
              <div class="bom-comp-stocks">
                <% if (isGlobalAdmin) { %>
                  <% branches.forEach(br => { %>
                    <%
                      const have = numberOf(comp.branches?.[br]?.have);
                      const chipClass = have >= needQty ? 'csc-ok' : (have === 0 ? 'csc-danger' : 'csc-warn');
                    %>
                    <div class="comp-stock-chip <%= chipClass %>">
                      <span class="csc-branch"><%= br %></span>
                      <span class="csc-have"><%= have %></span>
                      <span class="csc-need">Cần <%= needQty %></span>
                    </div>
                  <% }); %>
                <% } else if (userBranch) { %>
                  <%
                    const have = numberOf(comp.branches?.[userBranch]?.have);
                    const chipClass = have >= needQty ? 'csc-ok' : (have === 0 ? 'csc-danger' : 'csc-warn');
                  %>
                  <div class="comp-stock-chip <%= chipClass %>" style="min-width:110px;">
                    <span class="csc-branch"><%= userBranch %></span>
                    <span class="csc-have"><%= have %></span>
                    <span class="csc-need">Cần <%= needQty %></span>
                  </div>
                <% } else { %>
                  <div class="comp-stock-chip">
                    <span class="csc-branch">Tổng</span>
                    <span class="csc-have"><%= totalHave %></span>
                    <span class="csc-need">Cần <%= needQty %>/bộ</span>
                  </div>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div><!-- /bom-components-panel -->

      </div><!-- /bom-product-card -->
    <% }); %>
  </div><!-- /bom-card-list -->

  <!-- ── Pagination ── -->
  <div class="bom-pagination">
    <a href="<%= buildPageUrl(1) %>" class="btn btn-secondary" <%= page <= 1 ? 'disabled' : '' %>>⟪ Đầu</a>
    <a href="<%= buildPageUrl(page - 1) %>" class="btn btn-secondary" <%= page <= 1 ? 'disabled' : '' %>>⟨ Trước</a>
    <select onchange="window.location.href=this.value;" title="Chọn trang">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <% if (totalPages <= 100 || (i >= page - 5 && i <= page + 5) || i === 1 || i === totalPages) { %>
          <option value="<%= buildPageUrl(i) %>" <%= i === page ? 'selected' : '' %>>Trang <%= i %></option>
        <% } else if (i === page - 6 || i === page + 6) { %>
          <option disabled>...</option>
        <% } %>
      <% } %>
    </select>
    <span style="font-size:13px; color:#64748b;">/ <%= totalPages %></span>
    <a href="<%= buildPageUrl(page + 1) %>" class="btn btn-secondary" <%= page >= totalPages ? 'disabled' : '' %>>Sau ⟩</a>
    <a href="<%= buildPageUrl(totalPages) %>" class="btn btn-secondary" <%= page >= totalPages ? 'disabled' : '' %>>Cuối ⟫</a>
  </div>

</div><!-- /dash-card -->

<%- include('partials/toast') %>

<script>
// ── Toggle expand/collapse ──
function toggleBomCard(header) {
  const card = header.closest('.bom-product-card');
  const panel = card.querySelector('.bom-components-panel');
  const btn   = header.querySelector('.bom-toggle-btn');
  if (!panel) return;
  const isOpen = panel.classList.contains('open');
  panel.classList.toggle('open', !isOpen);
  btn.classList.toggle('open', !isOpen);
  btn.setAttribute('aria-label', isOpen ? 'Mở linh kiện' : 'Thu gọn linh kiện');
}

document.addEventListener('DOMContentLoaded', function () {
  const cardList   = document.getElementById('bomCardList');
  const cards      = Array.from(cardList.querySelectorAll('.bom-product-card'));
  const defaultMap = new Map(cards.map((c, i) => [c.dataset.sku, i]));
  let statusFilter = 'all';

  // ── Status filter ──
  function applyFilter() {
    let visible = 0;
    cards.forEach(c => {
      const hasBN = Number(c.dataset.bottleneckCount) > 0;
      const show = statusFilter === 'all'
        || (statusFilter === 'missing' && hasBN)
        || (statusFilter === 'ready'   && !hasBN);
      c.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    ['btnShowAll','btnOnlyReady','btnOnlyMissing'].forEach(id => {
      const btn = document.getElementById(id);
      if (!btn) return;
      const mine = (id === 'btnShowAll' && statusFilter === 'all')
                || (id === 'btnOnlyReady' && statusFilter === 'ready')
                || (id === 'btnOnlyMissing' && statusFilter === 'missing');
      btn.classList.toggle('active', mine);
      btn.setAttribute('aria-pressed', mine ? 'true' : 'false');
    });
  }

  document.getElementById('btnShowAll')?.addEventListener('click', () => { statusFilter = 'all'; applyFilter(); });
  document.getElementById('btnOnlyReady')?.addEventListener('click', () => { statusFilter = 'ready'; applyFilter(); });
  document.getElementById('btnOnlyMissing')?.addEventListener('click', () => { statusFilter = 'missing'; applyFilter(); });

  // ── Sort ──
  document.getElementById('bomSortSelect')?.addEventListener('change', function() {
    const mode = this.value;
    const sorted = [...cards].sort((a, b) => {
      if (mode === 'buildableAsc') {
        const d = Number(a.dataset.buildable) - Number(b.dataset.buildable);
        if (d !== 0) return d;
      } else if (mode === 'gapDesc') {
        const d = Number(b.dataset.gap) - Number(a.dataset.gap);
        if (d !== 0) return d;
      } else if (mode === 'bottleneckDesc') {
        const d = Number(b.dataset.bottleneckCount) - Number(a.dataset.bottleneckCount);
        if (d !== 0) return d;
      }
      return (defaultMap.get(a.dataset.sku) || 0) - (defaultMap.get(b.dataset.sku) || 0);
    });
    sorted.forEach(c => cardList.appendChild(c));
    applyFilter();
  });

  // ── Expand / Collapse all ──
  document.getElementById('btnExpandAll')?.addEventListener('click', () => {
    cards.filter(c => c.style.display !== 'none').forEach(c => {
      const panel = c.querySelector('.bom-components-panel');
      const btn   = c.querySelector('.bom-toggle-btn');
      if (panel) { panel.classList.add('open'); btn?.classList.add('open'); }
    });
  });
  document.getElementById('btnCollapseAll')?.addEventListener('click', () => {
    cards.forEach(c => {
      const panel = c.querySelector('.bom-components-panel');
      const btn   = c.querySelector('.bom-toggle-btn');
      if (panel) { panel.classList.remove('open'); btn?.classList.remove('open'); }
    });
  });

  // ── Export CSV ──
  document.getElementById('btnExportCsv')?.addEventListener('click', () => {
    const visible = cards.filter(c => c.style.display !== 'none');
    if (!visible.length) { alert('Không có dữ liệu để xuất.'); return; }
    const headers = ['SKU','Ten thanh pham','Ton tong','Rap duoc','Chenh Ton-Rap duoc','LK thieu'];
    const rows = visible.map(c => [
      c.dataset.sku,
      c.querySelector('.bom-product-name')?.textContent.trim() || '',
      c.dataset.finalStock,
      c.dataset.buildable,
      c.dataset.gap,
      c.dataset.bottleneckCount
    ]);
    const esc = v => { const s = String(v ?? ''); return /[",\n]/.test(s) ? `"${s.replace(/"/g,'""')}"` : s; };
    const csv = [headers, ...rows].map(r => r.map(esc).join(',')).join('\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url;
    a.download = 'bom-dashboard-' + new Date().toISOString().slice(0,19).replace(/[:T]/g,'-') + '.csv';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  applyFilter();
});
</script>

<%- include('partials/footer') %>
