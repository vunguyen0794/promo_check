    // --- HÀM XỬ LÝ CHỌN NHANH THỜI GIAN ---
    function setPeriod(type) {
        const d = new Date();
        
        // Helper: Format YYYY-MM-DD theo giờ địa phương
        const toLocalISO = (date) => {
            const offset = date.getTimezoneOffset() * 60000;
            return new Date(date.getTime() - offset).toISOString().slice(0, 10);
        }

        let start = new Date();
        let end = new Date(); // Hôm nay

        if (type === 'today') {
            // Start = End = Hôm nay
        } else if (type === 'week') {
            // Thứ 2 đầu tuần hiện tại
            const day = d.getDay(); 
            const diff = d.getDate() - day + (day === 0 ? -6 : 1); // adjust when day is sunday
            start.setDate(diff);
        } else if (type === 'month') {
            // Ngày 1 đầu tháng
            start.setDate(1);
        }

        // Gán giá trị vào ô input
        const startInput = document.querySelector('input[name="start"]');
        const endInput = document.querySelector('input[name="end"]');
        
        if(startInput && endInput) {
            startInput.value = toLocalISO(start);
            endInput.value = toLocalISO(end);
            
            // Tự động Submit form sau khi chọn xong ngày
            document.getElementById('adminFilterForm').submit();
        }
    }

    let currentBreakdownIndex = null; // Lưu index khách hàng đang xem

// 1. HÀM MỞ MODAL (CẤP 1)
function showOrderBreakdown(index) {
    currentBreakdownIndex = index;
    const cust = globalWorkListData[index];
    if (!cust || !cust.Orders) return;

    // Reset giao diện về cấp 1
    document.getElementById('breakdownNav').style.display = 'none';
    document.getElementById('breakdownCustomerName').innerText = `Khách hàng: ${cust.Customer_Name}`;

    const isGlobalAdmin = "<%= typeof isGlobalAdmin !== 'undefined' && isGlobalAdmin %>" === 'true';

    // Nếu là Admin -> Hiện danh sách Branch
    if (isGlobalAdmin) {
        renderBreakdownTable(cust.Orders, 'branch');
    } else {
        // Nếu là Manager -> Hiện danh sách Sales luôn
        renderBreakdownTable(cust.Orders, 'sales');
    }

    document.getElementById('breakdownModal').style.display = 'flex';
}

// 2. HÀM XEM CHI TIẾT BRANCH (CẤP 2 - Dành cho Admin)
function showBranchDetail(targetBranch) {
    const cust = globalWorkListData[currentBreakdownIndex];
    
    // Lọc ra các đơn hàng CHỈ thuộc chi nhánh vừa bấm
    const filteredOrders = cust.Orders.filter(o => o.Branch_code === targetBranch);

    // Hiển thị nút Back
    document.getElementById('breakdownNav').style.display = 'block';
    
    // Render lại bảng theo tiêu chí Sales
    renderBreakdownTable(filteredOrders, 'sales', targetBranch);
}

// 3. HÀM QUAY LẠI CẤP 1
function resetToBranchView() {
    // Gọi lại hàm gốc để render lại danh sách Branch
    showOrderBreakdown(currentBreakdownIndex);
}

// 4. HÀM RENDER CHUNG (CORE LOGIC)
function renderBreakdownTable(ordersList, mode, branchNameLabel = '') {
    const tbody = document.getElementById('breakdownTableBody');
    const titleCol = document.getElementById('breakdownColName');
    
    // Config tiêu đề
    if (mode === 'branch') titleCol.innerText = "Chi Nhánh (Click để xem)";
    else titleCol.innerText = branchNameLabel ? `Sales (${branchNameLabel})` : "Nhân viên Kinh doanh";

    // Gom nhóm dữ liệu
    const stats = {};
    let totalCount = 0;

    ordersList.forEach(order => {
        let key = 'N/A';
        if (mode === 'branch') {
            key = order.Branch_code || 'Chưa xác định';
        } else {
            // Lấy tên Sales từ email (trước @)
            const email = order.Sales_Email || 'N/A';
            key = email.split('@')[0];
        }
        stats[key] = (stats[key] || 0) + 1;
        totalCount++;
    });

    // Sort giảm dần
    const sortedStats = Object.entries(stats)
        .map(([name, count]) => ({ name, count }))
        .sort((a, b) => b.count - a.count);

    // Render HTML
    let html = '';
    sortedStats.forEach(item => {
        const percent = ((item.count / totalCount) * 100).toFixed(1);
        const barStyle = `background: linear-gradient(90deg, #dbeafe ${percent}%, transparent ${percent}%);`;
        
        // Logic Clickable: Chỉ click được nếu đang ở chế độ Branch view
        const isClickable = (mode === 'branch');
        const clickAttr = isClickable ? `onclick="showBranchDetail('${item.name}')"` : '';
        const rowClass = isClickable ? 'clickable-row' : '';
        const nameStyle = isClickable ? 'color:#2563eb; text-decoration:underline;' : 'color:#334155;';

        html += `
            <tr class="${rowClass}" style="${barStyle}" ${clickAttr}>
                <td style="font-weight:600; ${nameStyle}">
                    ${item.name} 
                    ${isClickable ? '<span style="float:right; font-size:10px;">👉</span>' : ''}
                </td>
                <td style="text-align:right; font-weight:700; color:#2563eb;">${item.count}</td>
                <td style="text-align:right; color:#64748b; font-size:12px;">${percent}%</td>
            </tr>
        `;
    });

    if (sortedStats.length === 0) {
        html = '<tr><td colspan="3" style="text-align:center; padding:10px;">Không có dữ liệu</td></tr>';
    }

    tbody.innerHTML = html;

    // 5. Hiển thị Modal
    document.getElementById('breakdownModal').style.display = 'flex';
}
// Hàm mở Popup Chi tiết Matrix
async function openMatrixDetail(userId, resultType, branchName) {
    // 1. Hiển thị Modal & Loading
    const modal = document.getElementById('matrixDetailModal');
    const tbody = document.getElementById('matrixDetailBody');
    const title = document.getElementById('matrixDetailTitle');
    
    // Lấy tháng đang chọn ở bộ lọc (để biết xem tháng nào)
    const currentMonth = document.getElementById('wlMonth').value; 
    // Nếu đang chọn "All" hoặc filter khác, mặc định lấy tháng hiện tại cho dashboard này (vì dashboard là "Tháng này")
    // Tuy nhiên dashboard của bạn đang cố định là "Tháng này" (logic server). 
    // Tốt nhất lấy giá trị từ input month, nếu 'all' thì fallback về tháng hiện tại.
    const d = new Date();
    const queryMonth = (currentMonth === 'all') ? d.toISOString().slice(0, 7) : currentMonth;

    title.innerText = `${resultType} - ${branchName} (Tháng ${queryMonth})`;
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center; padding:20px;">⏳ Đang tải dữ liệu...</td></tr>';
    modal.style.display = 'flex';

    try {
        // 2. Gọi API
        const res = await fetch(`/api/cskh/matrix-detail?userId=${userId}&resultType=${encodeURIComponent(resultType)}&month=${queryMonth}&branch=${encodeURIComponent(branchName)}`);
        const json = await res.json();

        if (json.ok) {
            if (json.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align:center; padding:20px; color:red;">Không tìm thấy dữ liệu chi tiết.</td></tr>';
            } else {
                // 3. Render dữ liệu
               const html = json.data.map(item => `
                        <tr>
                            <td style="text-align:center">${item.stt}</td>
                            <td><span class="badge badge-subgroup">${item.branch}</span></td>
                            <td>${item.salesman}</td>
                            
                            <td>
                                <a href="javascript:void(0)" 
                                   onclick="searchOrderFromModal('${item.order_code}')"
                                   style="font-weight:700; color:#2563eb; text-decoration:underline;">
                                   ${item.order_code}
                                </a>
                            </td>

                            <td>
                                <div style="font-weight:600;">${item.customer_name}</div>
                            </td>
                            <td>${item.phone}</td>
                            <td>${item.tax_code}</td>
                            
                            <td style="text-align:right; font-weight:700; color:#16a34a;">
                                ${new Intl.NumberFormat('vi-VN').format(item.revenue)} ₫
                            </td>

                            <td style="font-size:12px; color:#334155; text-align:left; white-space: normal;">
                                ${item.note || '-'}
                            </td>
                        </tr>
                    `).join('');
                    tbody.innerHTML = html;
                }
        } else {
            tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; color:red;">Lỗi: ${json.error}</td></tr>`;
        }
    } catch (e) {
        console.error(e);
        tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; color:red;">Lỗi kết nối máy chủ.</td></tr>`;
    }
}

// --- HÀM TÌM KIẾM TỪ MODAL (ĐÃ FIX: RESET BỘ LỌC) ---
function searchOrderFromModal(orderCode) {
    // 1. Đóng Modal hiện tại
    const modal = document.getElementById('matrixDetailModal');
    if (modal) modal.style.display = 'none';

    // 2. Điền thông tin vào ô tìm kiếm
    const searchType = document.getElementById('searchType');
    const searchInput = document.getElementById('searchInput');

    if(searchType && searchInput) {
        searchType.value = 'order_code'; // Chuyển loại tìm kiếm thành Mã đơn
        searchInput.value = orderCode;   // Điền mã đơn
        
        // 3. [QUAN TRỌNG] Reset tất cả bộ lọc về "Tất cả"
        // Để đảm bảo tìm thấy đơn hàng dù nó ở tháng cũ hay trạng thái khác
        
        // Reset Tháng -> Toàn thời gian
        const wlMonth = document.getElementById('wlMonth');
        if (wlMonth) wlMonth.value = 'all';

        // Reset Trạng thái -> Tất cả
        const wlStatus = document.getElementById('wlStatus');
        if (wlStatus) wlStatus.value = 'all';

        // Reset Loại thuế -> Tất cả
        const wlTax = document.getElementById('wlTax');
        if (wlTax) wlTax.value = 'all';

        // Reset Chi nhánh (cho Manager) -> Tất cả
        const wlBranch = document.getElementById('wlBranch');
        if (wlBranch) wlBranch.value = 'all';

        // Reset Nhân viên (nếu có) -> Tất cả
        if (typeof $ !== 'undefined' && $('#filterEmail').length > 0) {
            $('#filterEmail').val(null).trigger('change'); 
        } else {
            const filterEmail = document.getElementById('filterEmail');
            if (filterEmail) filterEmail.value = '';
        }
        
        // 4. Gọi hàm load dữ liệu
        loadWorkList(1);
        
        // 5. Cuộn màn hình xuống phần danh sách để user thấy ngay
        const targetSection = document.querySelector('.dash-card');
        if (targetSection) {
            targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }
}


