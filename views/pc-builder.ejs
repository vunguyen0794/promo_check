        </button>
        <button type="button" id="btnDownloadExcel" class="btn" style="flex: 1; padding: 12px; font-weight: 700; background-color: #107c41; color: white; border: none; border-radius: 6px; cursor: pointer;">
          <i class="fas fa-file-excel"></i> Xuất Excel
        </button>
      </div>
      
      <div id="downloadError" style="color: red; text-align: center; margin-top: 10px; display: none;"></div>
      <div id="quoteLoading" class="dash-muted" style="text-align: center; padding: 20px; display: none;">
        Đang tạo file PDF...
      </div>
    </form>
  </div>
</div>
<%- include('partials/toast') %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
  const currentUser = {
    role: "<%= user ? user.role : 'guest' %>",
    branch: "<%= user ? user.branch_code : '' %>"
  };
  
  let currentBuildConfig = {}; 
  let currentSlotType = null;
  let allComponentsCache = [];

  const modal = document.getElementById('componentModal');
  const modalClose = document.getElementById('componentModalClose');
  const modalTitle = document.getElementById('componentModalTitle');
  const modalList = document.getElementById('componentModalList');
  const componentSearch = document.getElementById('componentSearch');
  const summaryList = document.getElementById('summary-list');
  const totalPriceEl = document.getElementById('total-price');
  const mainComponentList = document.querySelector('.component-list');
  const promoContainer = document.getElementById('promo-results-container');
  const promoList = document.getElementById('promo-results-list');
  
  const priceHistoryModal = document.getElementById('priceHistoryModal');
  const phClose = document.getElementById('phClose');
  const phTbody = document.querySelector('#phTable tbody');
  const phSku = document.getElementById('phSku');
  const quoteModal = document.getElementById('quoteModal');
  const quoteClose = document.getElementById('quoteClose');
  const quoteForm = document.getElementById('quoteForm');
  const quoteLoading = document.getElementById('quoteLoading');
  const mainQuoteButton = document.querySelector('.builder-sidebar .btn-primary');

  function formatVND(n) {
    return new Intl.NumberFormat('vi-VN').format(Number(n || 0)) + ' VNĐ';
  }

function buildStockHtml(stockByBranch, userRole, userBranch) {
    let totalStock = 0;
    const branchEntries = [];

    // 1. Tính tổng và lấy danh sách các kho CÓ HÀNG (>0)
    if (stockByBranch) {
      for (const [branch, qty] of Object.entries(stockByBranch)) {
        if (qty > 0) {
          totalStock += qty;
          // Chuẩn hóa tên chi nhánh
          branchEntries.push([String(branch).trim().toUpperCase(), qty]);
        }
      }
    }

    // 2. Xử lý Badge Ưu tiên (Cho TẤT CẢ User có mã chi nhánh)
    let userBadgeHtml = '';
    
    // Lấy mã chi nhánh của người đang đăng nhập (Bỏ qua logic check quyền Manager)
    const myBranchCode = userBranch ? String(userBranch).trim().toUpperCase() : '';

    if (myBranchCode) {
        // Tìm xem kho của user có trong danh sách tồn > 0 không
        const myIndex = branchEntries.findIndex(e => e[0] === myBranchCode);
        
        if (myIndex > -1) {
            // CÓ HÀNG -> Badge Xanh Dương
            const qty = branchEntries[myIndex][1];
            userBadgeHtml = `
                <span style="display:inline-flex; align-items:center; font-weight:800; color:#fff; background-color:#2563eb; padding:2px 8px; border-radius:4px; font-size:12px; margin-right:4px; box-shadow:0 1px 2px rgba(0,0,0,0.2);">
                    ${myBranchCode}: ${qty}
                </span>`;
            
            // Xóa khỏi danh sách chung để không lặp lại phía sau
            branchEntries.splice(myIndex, 1);
        } else {
            // HẾT HÀNG -> Badge Đỏ (Luôn hiện để cảnh báo)
            userBadgeHtml = `
                <span style="display:inline-flex; align-items:center; font-weight:800; color:#fff; background-color:#dc2626; padding:2px 8px; border-radius:4px; font-size:12px; margin-right:4px; box-shadow:0 1px 2px rgba(0,0,0,0.2);">
                    ${myBranchCode}: 0
                </span>`;
        }
    }

    // 3. Sắp xếp các chi nhánh còn lại (A-Z)
    branchEntries.sort((a, b) => a[0].localeCompare(b[0]));

    // 4. Tạo Badge Xám cho các chi nhánh khác
    const otherBadges = branchEntries.map(([br, qty]) => {
        return `<span style="color:#334155; background-color:#f1f5f9; border:1px solid #cbd5e1; padding:1px 6px; border-radius:4px; font-size:11px;">${br}: ${qty}</span>`;
    }).join(''); 

    // 5. Kết hợp: Dòng 1 là Tổng, Dòng 2 là Badge User + Các kho khác
    return `
      <div style="margin-top: 6px;">
        <div style="font-weight: 700; color: #059669; font-size: 13px; margin-bottom: 4px;">
            Tổng tồn toàn hệ thống: ${totalStock}
        </div>
        
        <div style="display:flex; flex-wrap:wrap; gap:4px; align-items:center;">
            ${userBadgeHtml}
            ${otherBadges}
        </div>
      </div>
    `;
  }

  // GỌI API KIỂM TRA CTKM
  async function checkPromotions() {
    const totalPrice = Object.values(currentBuildConfig).reduce((sum, item) => {
      const price = item.edited_price !== undefined ? item.edited_price : (item.list_price || 0);
      return sum + (price * item.quantity);
    }, 0);
    promoContainer.style.display = 'block';
    if (totalPrice === 0) {
      promoList.innerHTML = `<div class="dash-muted" style="padding: 10px;">Vui lòng chọn linh kiện để kiểm tra KM.</div>`;
      return;
    }

    try {
      const res = await fetch('/api/pc-builder/check-promos', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          buildConfig: currentBuildConfig,
          totalPrice: totalPrice
        })
      });
      const data = await res.json();
      if (!data.ok) throw new Error(data.error);
      if (data.success) {
        const p = data.promo;
        promoList.innerHTML = `
          <div class="promo-item-card" style="background: #ecfdf5; border-color: #10b981;">
            <div class="promo-item-header">
              <span class="promo-item-name" style="color: #065f46;">${p.name}</span>
              <span class="promo-item-discount" style="color: #10b981;">-${formatVND(p.discount_amount)}</span>
            </div>
            <div class="promo-item-desc" style="color: #065f46; margin-top: 5px;">${p.description}</div>
            <button type="button" class="code-badge" onclick="copyCode(this)" data-code="${p.coupon}" style="margin-top: 10px;">
              🔑 <span>${p.coupon}</span> <small>(Bấm để copy)</small>
            </button>
          </div>
        `;
      } else {
        promoList.innerHTML = `
          <div class="promo-item-card" style="background: #fffbeb; border-color: #f59e0b;">
            <div class="promo-item-header">
              <span class="promo-item-name" style="color: #b45309;">Cấu hình chưa đạt KM</span>
            </div>
            <div class="promo-item-desc" style="color: #b45309; font-weight: 600; margin-top: 5px;">
              Lý do: ${data.reason || 'Lỗi không xác định.'}
            </div>
          </div>
        `;
      }
    } catch (err) {
      console.error("Lỗi khi check CTKM:", err.message);
      promoList.innerHTML = `<div class="error-message">Lỗi tải CTKM: ${err.message}</div>`;
    }
  }

  // HÀM CẬP NHẬT TỔNG TIỀN & TÓM TẮT
  function updateSummaryAndTotal() {
    let totalPrice = 0;
    let summaryHtml = '';
    const orderedKeys = Array.from(mainComponentList.querySelectorAll('.component-slot')).map(s => s.id.replace('slot-', ''));
    
    for (const type of orderedKeys) {
      const item = currentBuildConfig[type];
      if (item) {
        if (!item.quantity || item.quantity < 1) item.quantity = 1;
        const currentPrice = item.edited_price !== undefined ? item.edited_price : (item.list_price || 0);
        const itemPrice = currentPrice * (item.quantity);
        totalPrice += itemPrice;
        
        let priceHtml = '';
        if (item.isEditingPrice) {
          priceHtml = `
            <div class="price-edit-controls">
              <input type="number" value="${currentPrice}" id="price-input-${type}" style="width: 100px;">
              <button class="btn-price-action" data-type="${type}" data-action="save-price">✔️</button>
              <button class="btn-price-action" data-type="${type}" data-action="cancel-price">✖️</button>
            </div>`;
        } else {
          let priceDisplay = formatVND(currentPrice);
          if (item.edited_price !== undefined && item.edited_price !== item.list_price) {
             priceDisplay = `<strong style="color: #10b981;">${formatVND(item.edited_price)}</strong>`;
          }
          priceHtml = `
            <span>${priceDisplay}</span>
            <button class="btn-price-action btn-edit-price" data-type="${type}" title="Sửa giá">✏️</button>
            <button class="btn-price-action btn-history-price" data-sku="${item.sku}" title="Lịch sử giá">🕘</button>
          `;
        }

        summaryHtml += `
          <div class="summary-item">
            <div class="summary-item-info">
              <span class="summary-item-name">${item.product_name}</span>
              <span style="font-size: 12px; color: #64748b; margin-top: 2px; display: block;">SKU: ${item.sku}</span>
              <div class="quantity-controls">
                <button class="qty-btn" data-type="${type}" data-action="decrease" ${item.quantity <= 1 ? 'disabled' : ''}>-</button>
                <span class="qty-display">${item.quantity}</span>
                <button class="qty-btn" data-type="${type}" data-action="increase">+</button>
              </div>
            </div>
            <div class="summary-item-price" id="price-display-${type}">
              ${priceHtml}
            </div>
          </div>
        `;
      }
    }

    if (summaryHtml === '') {
      summaryList.innerHTML = `<div class="dash-muted" style="text-align: center; padding: 20px 0;">Vui lòng chọn linh kiện</div>`;
    } else {
      summaryList.innerHTML = summaryHtml;
    }
    totalPriceEl.textContent = formatVND(totalPrice);
    checkPromotions();
  }

  function changeQuantity(type, action) {
    const item = currentBuildConfig[type];
    if (!item) return;
    if (action === 'increase') {
      item.quantity += 1;
    } else if (action === 'decrease') {
      if (item.quantity > 1) item.quantity -= 1;
    }
    updateSummaryAndTotal();
  }

  function renderComponentList(components) {
    if (components.length === 0) {
      modalList.innerHTML = '<div class="dash-muted" style="text-align: center; padding: 20px;">Không tìm thấy linh kiện nào.</div>';
      return;
    }
    modalList.innerHTML = components.map(item => {
      const stockHtml = buildStockHtml(item.stock_by_branch, currentUser.role, currentUser.branch);
      return `
      <div class="component-item">
        <div class="component-item-main-row">
          <div class="component-item-info">
            <strong>${item.product_name}</strong><br>
            <span>SKU: ${item.sku} | Brand: ${item.brand || 'N/A'}</span>
          </div>
          <div class="component-item-action">
            <span class="component-item-price">${formatVND(item.list_price)}</span>
            <button class="btn-select-item" data-sku="${item.sku}">Chọn</button>
          </div>
        </div>
        <div class="component-item-stock">${stockHtml}</div>
      </div>
      `;
    }).join('');
  }
  
  async function showPriceHistoryModal(sku) {
    phSku.textContent = sku;
    phTbody.innerHTML = '<tr><td colspan="4">Đang tải...</td></tr>';
    priceHistoryModal.style.display = 'flex';
    try {
      const res = await fetch(`/api/sku/${sku}/price-history`);
      const js = await res.json();
      if (!js.ok) throw new Error(js.error || 'Load history failed');
      const rows = (js.history || []).map(r => `
        <tr>
          <td>${new Date(r.changed_at).toLocaleString('vi-VN')}</td>
          <td style="text-align: right;">${formatVND(r.old_price)}</td>
          <td style="text-align: right;">${formatVND(r.new_price)}</td>
          <td>${r.user || '-'}</td>
        </tr>
      `).join('');
      phTbody.innerHTML = rows || '<tr><td colspan="4">Chưa có lịch sử</td></tr>';
    } catch (e) {
      phTbody.innerHTML = `<tr><td colspan="4" class="error-message">Lỗi: ${e.message}</td></tr>`;
    }
  }

  // ----- EVENTS -----
  mainComponentList.addEventListener('click', async (e) => {
    // CHỌN SLOT
    if (e.target.classList.contains('btn-choose')) {
      const btn = e.target;
      let subcat = btn.dataset.subcat; 
      const subcatPrefix = subcat.split('-').slice(0, 3).join('-'); 
      currentSlotType = btn.dataset.type;
      const slotNameEl = btn.closest('.component-slot').querySelector('.component-name');
      const slotName = slotNameEl.dataset.originalTitle;
      modalTitle.textContent = `Chọn - ${slotName}`;
      modal.style.display = 'flex';
      componentSearch.value = '';
      modalList.innerHTML = '<div class="dash-muted" style="text-align: center; padding: 20px;">Đang tải...</div>';
      try {
        const res = await fetch(`/api/components?subcat=${subcatPrefix}`); 
        const data = await res.json();
        if (!data.ok) throw new Error(data.error);
        allComponentsCache = data.components;
        renderComponentList(allComponentsCache);
      } catch (err) {
        modalList.innerHTML = `<div class="error-message">Lỗi: ${err.message}</div>`;
      }
    }
    
    // XÓA SLOT
    if (e.target.classList.contains('btn-remove')) {
      const btn = e.target;
      const slotType = btn.dataset.type;
      delete currentBuildConfig[slotType];
      const slotEl = document.getElementById(`slot-${slotType}`);
      const infoEl = slotEl.querySelector('.component-info');
      const originalTitle = infoEl.querySelector('.component-name').dataset.originalTitle;
      infoEl.innerHTML = `
        <div class="component-name" data-original-title="${originalTitle}">
          <strong>${originalTitle}:</strong><span class="placeholder">Chưa chọn</span>
        </div>
        <div class="component-price-display"></div>
      `;
      btn.textContent = 'Chọn';
      btn.classList.remove('btn-danger', 'btn-remove');
      btn.classList.add('btn-primary', 'btn-choose');
      updateSummaryAndTotal();
    }
  });

  // EVENTS SIDEBAR
  summaryList.addEventListener('click', async (e) => {
    const btn = e.target.closest('button');
    if (!btn) return;
    const type = btn.dataset.type;
    const action = btn.dataset.action;
    
    if (action === 'increase' || action === 'decrease') changeQuantity(type, action);
    if (btn.classList.contains('btn-edit-price')) {
      const item = currentBuildConfig[type];
      if (item) {
        item.isEditingPrice = true;
        updateSummaryAndTotal();
        setTimeout(() => document.getElementById(`price-input-${type}`).focus(), 50);
      }
    }
    if (btn.classList.contains('btn-history-price')) {
      const sku = btn.dataset.sku;
      showPriceHistoryModal(sku);
    }
    if (action === 'save-price') {
      const item = currentBuildConfig[type];
      const inputEl = document.getElementById(`price-input-${type}`);
      const newPrice = Number(inputEl.value);
      if (!item || newPrice < 0) return alert('Giá không hợp lệ');
      
      btn.disabled = true;
      try {
        const res = await fetch(`/api/sku/${item.sku}/price`, {
          method: 'POST', headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ new_price: newPrice })
        });
        const js = await res.json();
        if (!js.ok) throw new Error(js.error || 'Cập nhật giá thất bại');
        item.edited_price = newPrice;
        item.isEditingPrice = false;
        showToast('Đã lưu giá mới thành công!', 'success');
      } catch (err) {
        alert('Lỗi lưu giá: ' + err.message);
        btn.disabled = false;
      }
      updateSummaryAndTotal();
    }
    if (action === 'cancel-price') {
      const item = currentBuildConfig[type];
      if (item) { item.isEditingPrice = false; updateSummaryAndTotal(); }
    }
  });

  modalList.addEventListener('click', (e) => {
    if (e.target.classList.contains('btn-select-item')) {
      const sku = e.target.dataset.sku;
      const selectedItem = allComponentsCache.find(c => c.sku === sku);
      if (selectedItem && currentSlotType) {
        currentBuildConfig[currentSlotType] = { ...selectedItem, quantity: 1 };
        const slotEl = document.getElementById(`slot-${currentSlotType}`);
        const infoEl = slotEl.querySelector('.component-info');
        const originalTitle = infoEl.querySelector('.component-name').dataset.originalTitle;
        infoEl.innerHTML = `
          <div class="component-name" data-original-title="${originalTitle}">
            <strong>${originalTitle}:</strong><span style="font-weight: 400; margin-left: 5px;">${selectedItem.product_name}</span>
          </div>
          <div class="component-price-display">${formatVND(selectedItem.list_price)}</div>
        `;
        const btnEl = slotEl.querySelector('button');
        btnEl.textContent = 'Xóa';
        btnEl.classList.remove('btn-primary', 'btn-choose');
        btnEl.classList.add('btn-danger', 'btn-remove');
        updateSummaryAndTotal();
        modal.style.display = 'none';
        currentSlotType = null;
      }
    }
  });

  componentSearch.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase().trim();
    const filtered = allComponentsCache.filter(c => c.product_name.toLowerCase().includes(query) || c.sku.toLowerCase().includes(query));
    renderComponentList(filtered);
  });

  modalClose.onclick = () => { modal.style.display = 'none'; };
  if (phClose) phClose.onclick = () => { priceHistoryModal.style.display = 'none'; };
  window.onclick = (e) => {
    if (e.target == modal) modal.style.display = 'none';
    if (priceHistoryModal && e.target == priceHistoryModal) priceHistoryModal.style.display = 'none';
    if (quoteModal && e.target == quoteModal) quoteModal.style.display = 'none';
  };

  mainQuoteButton.addEventListener('click', (e) => {
    e.preventDefault();
    if (Object.keys(currentBuildConfig).length === 0) {
      showToast('Vui lòng chọn ít nhất 1 linh kiện', 'warn');
      return;
    }
    quoteModal.style.display = 'flex';
    quoteLoading.style.display = 'none';
    // Đảm bảo nút tải hiển thị lại khi mở modal
    const btnDownload = document.getElementById('btnDownloadPDF');
    if (btnDownload) { btnDownload.style.display = 'block'; btnDownload.disabled = false; }
    const btnExcel = document.getElementById('btnDownloadExcel');
    if (btnExcel) { btnExcel.style.display = 'block'; btnExcel.disabled = false; }
    document.getElementById('downloadError').style.display = 'none';
  });

  // --- XỬ LÝ NÚT TẢI PDF (FIXED WITH EVENT DELEGATION) ---
  document.addEventListener('click', async (e) => {
    if (e.target && e.target.id === 'btnDownloadPDF') {
        const btnDownload = e.target;
        
        const name = document.getElementById('quoteCustomerName').value.trim();
        const phone = document.getElementById('quoteCustomerPhone').value.trim();
        const contact = document.getElementById('quoteContactInfo').value.trim();
        const notes = document.getElementById('quoteNotes').value.trim();
        
        if (!name || !phone || !contact) {
            alert('Vui lòng nhập đủ thông tin khách hàng và liên hệ!');
            return;
        }

        btnDownload.style.display = 'none';
        quoteLoading.style.display = 'block';
        document.getElementById('downloadError').style.display = 'none';

        // Lấy tham số mới
        const validityDays = document.getElementById('quoteValidity').value;
        let templateType = 'consumer';
        const checkedRadio = document.querySelector('input[name="printTemplate"]:checked');
        if (checkedRadio) templateType = checkedRadio.value;

        try {
          const res = await fetch('/api/pc-builder/generate-quote', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
              buildConfig: currentBuildConfig,
              customerName: name,
              customerPhone: phone,
              contactInfo: contact,
              notes: notes,
              sendEmail: false, 
              isGeneralQuote: false, // Build PC -> Có KM
              
              // Gửi option mới
              validityDays: validityDays,
              templateType: templateType,
              globalDiscount: { value: 0, type: 'amount' } 
            })
          });
          
          if (!res.ok) {
              const errJson = await res.json();
              throw new Error(errJson.error || 'Lỗi server');
          }

          const blob = await res.blob();
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.style.display = 'none'; a.href = url;
          const safeName = name.replace(/[^a-zA-Z0-9\u00C0-\u1EF9]/g, '_');
          a.download = `BaoGia_${safeName}.pdf`;
          
          document.body.appendChild(a); a.click();
          
          window.URL.revokeObjectURL(url);
          setTimeout(() => document.body.removeChild(a), 100);
          
          document.getElementById('quoteModal').style.display = 'none';
          if(typeof showToast === 'function') showToast('Đã tải báo giá thành công!', 'success');

        } catch (err) {
          console.error("Lỗi tải PDF:", err);
          const errorDiv = document.getElementById('downloadError');
          if (errorDiv) {
              errorDiv.innerText = 'Lỗi: ' + err.message;
              errorDiv.style.display = 'block';
          } else {
              alert('Lỗi: ' + err.message);
          }
        } finally {
          btnDownload.style.display = 'block';
          const btnExcel = document.getElementById('btnDownloadExcel');
          if (btnExcel) btnExcel.style.display = 'block';
          quoteLoading.style.display = 'none';
        }
    } else if (e.target && e.target.id === 'btnDownloadExcel') {
        const btnDownload = e.target;
        
        const name = document.getElementById('quoteCustomerName').value.trim();
        const phone = document.getElementById('quoteCustomerPhone').value.trim();
        const contact = document.getElementById('quoteContactInfo').value.trim();
        const notes = document.getElementById('quoteNotes').value.trim();
        
        if (!name || !phone || !contact) {
            alert('Vui lòng nhập đủ thông tin khách hàng và liên hệ!');
            return;
        }

        btnDownload.style.display = 'none';
        const btnPdf = document.getElementById('btnDownloadPDF');
        if (btnPdf) btnPdf.style.display = 'none';
        
        quoteLoading.style.display = 'block';
        document.getElementById('downloadError').style.display = 'none';

        // Lấy tham số mới
        const validityDays = document.getElementById('quoteValidity').value;
        let templateType = 'consumer';
        const checkedRadio = document.querySelector('input[name="printTemplate"]:checked');
        if (checkedRadio) templateType = checkedRadio.value;

        try {
          const res = await fetch('/api/pc-builder/generate-quote-excel', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
              buildConfig: currentBuildConfig,
              customerName: name,
              customerPhone: phone,
              contactInfo: contact,
              notes: notes,
              sendEmail: false, 
              isGeneralQuote: false, 
              validityDays: validityDays,
              templateType: templateType,
              globalDiscount: { value: 0, type: 'amount' } 
            })
          });
          
          if (!res.ok) {
              const errJson = await res.json();
              throw new Error(errJson.error || 'Lỗi server');
          }

          const blob = await res.blob();
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.style.display = 'none'; a.href = url;
          const safeName = name.replace(/[^a-zA-Z0-9\u00C0-\u1EF9]/g, '_');
          a.download = `BaoGia_${safeName}.xlsx`;
          
          document.body.appendChild(a); a.click();
          
          window.URL.revokeObjectURL(url);
          setTimeout(() => document.body.removeChild(a), 100);
          
          document.getElementById('quoteModal').style.display = 'none';
          if(typeof showToast === 'function') showToast('Đã tải báo giá Excel thành công!', 'success');

        } catch (err) {
          console.error("Lỗi tải Excel:", err);
          const errorDiv = document.getElementById('downloadError');
          if (errorDiv) {
              errorDiv.innerText = 'Lỗi: ' + err.message;
              errorDiv.style.display = 'block';
          } else {
              alert('Lỗi: ' + err.message);
          }
        } finally {
          btnDownload.style.display = 'block';
          if (btnPdf) btnPdf.style.display = 'block';
          quoteLoading.style.display = 'none';
        }
    }
  });

  updateSummaryAndTotal();
});
</script>

<%- include('partials/footer') %>