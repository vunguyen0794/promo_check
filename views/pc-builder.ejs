<%- include('partials/header', { title: 'Xây dựng cấu hình PC', currentPage: 'pc-builder' }) %>

<style>
  /* CSS riêng cho trang này */
  .pc-builder-layout {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* === CSS CHO SLOT CHÍNH (BÊN TRÁI) === */
  .component-list .component-slot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px;
    border: 1px dashed #e5e7eb;
    border-radius: 12px;
    margin-bottom: 12px;
  }
  
  /* Thông tin (Tên + Giá) */
  .component-list .component-info {
    flex-grow: 1;
    margin-right: 15px; /* Khoảng cách với nút */
  }

  /* Tên slot (VD: 1. CPU: ... ) */
  .component-list .component-name {
    font-size: 16px;
    font-weight: 400; /* Chữ thường */
    color: #111827;
  }
  .component-list .component-name strong {
    font-weight: 800; /* Chữ đậm cho tiêu đề */
  }
  .component-list .component-name .placeholder {
    font-weight: 400;
    color: #64748b;
    font-style: italic;
    margin-left: 5px;
  }
  
  /* Giá (sẽ được JS điền vào) */
  .component-list .component-price-display {
    font-size: 14px;
    color: #e53935; /* Màu giá */
    font-weight: 700;
    margin-top: 4px;
    height: 1.2em; /* Giữ 1 khoảng trống nhỏ */
  }

  /* Nút (Dùng class gốc 'btn' từ style.css) */
  .component-list .btn {
    padding: 8px 14px;
    font-weight: 600;
    flex-shrink: 0; /* Không bị co nút */
  }
  
  /* === CSS CHO CỘT TÓM TẮT (BÊN PHẢI) === */
  .price-summary-sticky {
    position: sticky;
    top: 80px;
  }
  .summary-item {
    display: flex;
    justify-content: space-between;
    align-items: center; /* Căn giữa tên/nút và giá */
    font-size: 14px;
    margin-bottom: 10px;
  }
  .summary-item-info {
    flex-grow: 1; /* Cho phép khối tên co giãn */
    margin-right: 10px;
  }
  .summary-item-name {
    display: block; /* Tên SP ở 1 hàng */
  }
  .summary-item-price {
    font-weight: 600;
    text-align: right;
    min-width: 100px;
    flex-shrink: 0; /* Không co lại */
  }
  .quantity-controls {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 4px;
  }
  .qty-btn {
    width: 24px;
    height: 24px;
    border: 1px solid #cbd5e1;
    background-color: #f8fafc;
    color: #475569;
    border-radius: 999px; /* Tròn */
    cursor: pointer;
    font-weight: 600;
    line-height: 1; /* Căn số */
  }
  .qty-btn:hover {
    background-color: #e2e8f0;
  }
  .qty-display {
    font-weight: 600;
    padding: 0 5px;
    min-width: 20px;
    text-align: center;
  }

  /* === CSS CHO MODAL CHỌN LINH KIỆN (ĐÃ FIX LỆCH NÚT) === */
  .component-item {
    display: flex;
    flex-direction: column; /* Xếp dọc trước */
    align-items: stretch; /* Kéo giãn ra */
    padding: 12px;
    border-bottom: 1px solid #f1f5f9;
  }
  .component-item:hover { background-color: #f8fafc; }

  .component-item-main-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start; /* Căn trên để tránh nút bị kéo */
    width: 100%;
    gap: 15px;
  }
  .component-item-info { 
    font-size: 14px; 
    flex-grow: 1;
    line-height: 1.5;
  }
  .component-item-info strong { color: #111827; }
  .component-item-info span { color: #64748b; font-size: 12px; }
  
  .component-item-action {
    display: flex;
    flex-direction: column; /* Xếp giá và nút dọc */
    align-items: flex-end; /* Căn phải */
    gap: 8px;
    flex-shrink: 0;
    min-width: 100px;
  }
  .component-item-price { font-weight: 700; color: #e53935; text-align: right; }
  
  .btn-select-item {
    padding: 6px 16px; font-size: 13px; font-weight: 600; 
    border-radius: 6px; cursor: pointer; white-space: nowrap; 
    background-color: #10b981; color: white; border: none;
  }

  /* Tồn kho */
  .component-item-stock {
    font-size: 12px;
    color: #475569;
    margin-top: 8px;
    width: 100%;
    overflow-x: auto;
    white-space: nowrap;
    padding-bottom: 2px;
    scrollbar-width: none;
  }
  .component-item-stock::-webkit-scrollbar { display: none; }
  .component-item-stock .stock-total { font-weight: 700; color: #059669; padding-right: 5px; }
  .component-item-stock .stock-branch { color: #475569; padding: 0 5px; border-left: 1px solid #e5e7eb; }
  .component-item-stock .my-branch { font-weight: 700; color: #2563eb; }

  /* === BỐ CỤC 2 CỘT DESKTOP === */
  @media (min-width: 992px) {
    .pc-builder-layout {
      flex-direction: row;
      align-items: flex-start;
    }
    .builder-main { flex: 2; }
    .builder-sidebar { flex: 1; }
  }

  /* === CSS CHO SỬA GIÁ === */
  .summary-item-price {
    display: flex;
    align-items: center;
    justify-content: flex-end; 
  }
  .price-edit-controls {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .price-edit-controls input {
    width: 100px;
    padding: 5px 8px;
    border: 1px solid #2563eb;
    border-radius: 6px;
  }
  .btn-price-action {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: 4px;
    opacity: 0.6;
  }
  .btn-price-action:hover { opacity: 1; }

  /* === CSS CHO KHỐI CTKM === */
  .promo-item-card {
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 12px 15px;
    margin-bottom: 10px;
    background: #f8fafc;
  }
  .promo-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .promo-item-name { font-weight: 700; color: #111827; }
  .promo-item-discount { font-weight: 800; font-size: 16px; color: #e53935; }
  .promo-item-desc { font-size: 13px; color: #475569; margin-top: 4px; }
  .code-badge {
      background: #fff; border: 1px dashed #10b981; color: #065f46;
      padding: 4px 8px; border-radius: 4px; font-size: 12px; cursor: pointer;
  }
</style>

