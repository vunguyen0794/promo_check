    height: 68px;
    border-radius: 8px;
    object-fit: cover;
}

.news-mini-item__meta {
    min-width: 0;
}

.news-mini-item__meta strong {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
