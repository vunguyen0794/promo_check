.news-mini-list {
    margin-top: 12px;
    display: grid;
    gap: 10px;
}

.news-mini-item {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 10px;
    align-items: center;
    text-decoration: none;
    color: inherit;
    border: 1px solid #d8e5f5;
