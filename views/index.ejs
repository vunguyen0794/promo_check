    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
}

.runner-card__head {
    position: relative;
    width: 74px;
    height: 74px;
    margin: 0 auto 8px;
}

.runner-card__head img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
}

.runner-card__head span {
    position: absolute;
    left: 50%;
    bottom: -7px;
    transform: translateX(-50%);
    border-radius: 999px;
    padding: 2px 8px;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
}

.runner-card--silver .runner-card__head img {
    border: 3px solid #94a3b8;
}

.runner-card--silver .runner-card__head span {
    background: #64748b;
}

.runner-card--bronze .runner-card__head img {
    border: 3px solid #cd7f32;
}

.runner-card--bronze .runner-card__head span {
    background: #9a3412;
}

.runner-card strong {
    display: block;
    font-size: 13px;
    line-height: 1.4;
}

.runner-card small {
    color: #64748b;
    font-size: 11px;
}

.runner-card__score {
    margin-top: 6px;
    font-size: 12px;
    font-weight: 700;
    color: #9a3412;
}

.ranking-tail-list {
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 6px;
}

.ranking-tail-list li {
    display: grid;
    grid-template-columns: 50px minmax(0, 1fr) auto;
    align-items: center;
    gap: 8px;
    border: 1px solid #d9e5f5;
    border-radius: 10px;
    padding: 8px 10px;
    background: #f7fbff;
}

.ranking-tail-list__rank {
    font-weight: 800;
    color: #334155;
}

.ranking-tail-list__name {
    font-size: 13px;
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.ranking-tail-list__store {
    font-size: 11px;
    color: #64748b;
    white-space: nowrap;
}

.panel-empty {
    border: 1px dashed #bfd3ea;
    border-radius: 12px;
    padding: 18px;
    text-align: center;
    color: #5f738d;
    background: #f5f9ff;
}

@media (max-width: 1220px) {
    .home-layout {
        grid-template-columns: minmax(0, 1fr);
    }
}

@media (max-width: 900px) {
    .home-shell {
        width: 100%;
        max-width: 100%;
        margin-top: 12px;
        padding: 12px;
        border-radius: 22px;
    }

    .panel-head {
        flex-direction: column;
    }

    .promo-filters-bar {
        grid-template-columns: minmax(0, 1fr);
    }

    .promo-filter-toggle {
        width: fit-content;
    }

    .home-right-rail {
        display: flex;
        flex-direction: column;
    }

    .home-ranking {
        order: 1;
    }

    .home-news {
        order: 2;
    }
}

@media (max-width: 680px) {
    #promo-list-content .promo-list {
        grid-template-columns: 1fr;
    }

    .promo-list-content {
        max-height: 560px;
        padding: 10px;
    }

    .ranking-runners-up {
        grid-template-columns: 1fr;
    }

    .news-mini-item {
        grid-template-columns: 80px minmax(0, 1fr);
    }

    .news-mini-item img {
        width: 80px;
        height: 58px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const contentTarget = document.getElementById('promo-list-content');
    if (!contentTarget) return;

    const listViewport = document.getElementById('promo-list-viewport');
    const groupSelect = document.getElementById('promoGroupSelect');
    const searchInput = document.getElementById('promoSearchInput');
    const expiringToggle = document.getElementById('promoExpiringOnly');
    const spinner = document.getElementById('loading-spinner');
    const prevBtn = document.getElementById('promoPrevBtn');
    const nextBtn = document.getElementById('promoNextBtn');

    const visibleCountEl = document.getElementById('promo-visible-count');
    const totalCountEl = document.getElementById('promo-total-count');
    const urgentCountEl = document.getElementById('promo-urgent-count');
    const pageIndicatorEl = document.getElementById('promo-page-indicator');
    const pageIndicatorBottomEl = document.getElementById('promo-page-indicator-bottom');

    let debounceTimer;
    let currentPage = Number(<%= page %>) || 1;
    let totalPages = Number(<%= totalPages %>) || 1;
    let totalItems = Number(<%= displayTotalItems %>) || 0;
    let isLoading = false;

    function updateHeaderCounters() {
        const cards = Array.from(listViewport.querySelectorAll('.promo-item'));
        const visibleCards = cards.filter(function(card) { return card.style.display !== 'none'; });
        const urgentCards = visibleCards.filter(function(card) { return card.dataset.expiryLevel === 'urgent'; });
        const pageText = `${Math.min(currentPage, totalPages)}/${Math.max(totalPages, 1)}`;

        if (visibleCountEl) visibleCountEl.textContent = String(visibleCards.length);
        if (totalCountEl) totalCountEl.textContent = String(totalItems);
        if (urgentCountEl) urgentCountEl.textContent = String(urgentCards.length);
        if (pageIndicatorEl) pageIndicatorEl.textContent = pageText;
        if (pageIndicatorBottomEl) pageIndicatorBottomEl.textContent = `Trang ${pageText}`;

        if (prevBtn) prevBtn.disabled = currentPage <= 1 || isLoading;
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages || isLoading;
    }

    function syncMeta(scope) {
        const host = scope || listViewport;
        const meta = host.querySelector('.promo-fetch-meta');
        if (!meta) return;

        const parsedTotalPages = Number(meta.dataset.totalPages);
        const parsedTotalItems = Number(meta.dataset.totalItems);

        if (!Number.isNaN(parsedTotalPages) && parsedTotalPages > 0) {
            totalPages = parsedTotalPages;
        }
        if (!Number.isNaN(parsedTotalItems) && parsedTotalItems >= 0) {
            totalItems = parsedTotalItems;
        }
    }

    function applyExpiringFilter() {
        if (!expiringToggle) return;

        const onlyUrgent = expiringToggle.checked;
        listViewport.querySelectorAll('.promo-item').forEach(function(card) {
            const isUrgent = card.dataset.expiryLevel === 'urgent';
            card.style.display = (onlyUrgent && !isUrgent) ? 'none' : '';
        });
    }

    function parseChunk(html) {
        const temp = document.createElement('div');
        temp.innerHTML = html;
        const chunk = temp.querySelector('.promo-page-chunk');
        return { temp, chunk };
    }

    async function fetchPromos(pageToLoad) {
        if (isLoading) return;

        const nextPage = Number(pageToLoad) || 1;
        if (nextPage < 1) return;
        if (totalPages > 0 && nextPage > totalPages) return;
        const group = groupSelect ? groupSelect.value : '';
        const q = searchInput ? searchInput.value.trim() : '';

        const params = new URLSearchParams();
        if (group) params.append('group', group);
        if (q) params.append('q', q);
        params.append('page', String(nextPage));

        const queryString = params.toString();
        const apiUrl = '/api/featured-promos?' + queryString;

        try {
            isLoading = true;
            if (spinner) spinner.style.display = 'block';
            contentTarget.classList.add('is-loading');
            updateHeaderCounters();

            window.history.replaceState(null, '', queryString ? ('/?' + queryString) : '/');

            const response = await fetch(apiUrl, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) {
                throw new Error('Không thể tải danh sách CTKM');
            }

            const html = await response.text();
            const parsed = parseChunk(html);
            listViewport.innerHTML = parsed.chunk ? parsed.chunk.outerHTML : html;
            currentPage = nextPage;

            syncMeta(listViewport);
            applyExpiringFilter();
            updateHeaderCounters();
        } catch (error) {
            console.error('Lỗi tải CTKM:', error);
        } finally {
            isLoading = false;
            contentTarget.classList.remove('is-loading');
            if (spinner) spinner.style.display = 'none';
            updateHeaderCounters();
        }
    }

    if (groupSelect) {
        groupSelect.addEventListener('change', function() {
            fetchPromos(1);
        });
    }

    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(function() {
                fetchPromos(1);
            }, 450);
        });
    }

    if (expiringToggle) {
        expiringToggle.addEventListener('change', function() {
            applyExpiringFilter();
            updateHeaderCounters();
        });
    }

    if (prevBtn) {
        prevBtn.addEventListener('click', function() {
            fetchPromos(currentPage - 1);
        });
    }

    if (nextBtn) {
        nextBtn.addEventListener('click', function() {
            fetchPromos(currentPage + 1);
        });
    }

    syncMeta(listViewport);
    applyExpiringFilter();
    updateHeaderCounters();
});
</script>

