.ranking-champion__avatar-wrap {
    position: relative;
    width: 124px;
    height: 124px;
    margin: 0 auto 10px;
}

.ranking-champion__avatar-wrap img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #f6d27a;
}

.ranking-medal {
    position: absolute;
    right: -4px;
    bottom: 2px;
    border-radius: 999px;
