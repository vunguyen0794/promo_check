.ranking-medal--gold {
    background: #a16207;
}

.ranking-champion h3 {
    margin: 0;
    font-size: 19px;
    letter-spacing: 0.01em;
}

.ranking-champion p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 12px;
}

.ranking-score {
    margin-top: 8px;
    font-size: 14px;
    font-weight: 700;
    color: #9a3412;
    background: #fff1d6;
    border: 1px solid #f7d7a1;
    border-radius: 999px;
    display: inline-flex;
    padding: 4px 10px;
}

.ranking-runners-up {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
}

.runner-card {
    border-radius: 15px;
