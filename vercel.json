{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-clearance",
      "schedule": "0 1,7 * * *"
    },
    {
      "path": "/api/cron/sync-bq-skus",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/sync-inventory",
      "schedule": "30 0 * * *"
    }
  ]
}